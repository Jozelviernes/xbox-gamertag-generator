---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import { blogPosts } from "../data/blogPosts";

export async function getStaticPaths() {
  const { blogPosts } = await import("../data/blogPosts");
  return blogPosts.map((post) => ({ params: { slug: post.slug } }));
}

type TocItem = {
  id: string;
  title: string;
  level: number;
};

const { slug } = Astro.params;
const post = blogPosts.find((p) => p.slug === slug);

if (!post) {
  return Astro.redirect("/blog");
}

const relatedPosts = blogPosts.filter((p) => p.slug !== slug).slice(0, 3);
const articleUrl = `https://xboxgamertaggenerator.com/${post.slug}`;

const slugify = (text: string) =>
  text
    .toLowerCase()
    .replace(/&amp;|&/g, " and ")
    .replace(/<[^>]*>/g, "")
    .replace(/[^a-z0-9\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-");

const toc: TocItem[] = [];
const idCounts = new Map<string, number>();

const contentWithIds = post.content.replace(
  /<h([23])>(.*?)<\/h\1>/gi,
  (_match, level, rawTitle) => {
    const plainTitle = rawTitle
      .replace(/<[^>]+>/g, "")
      .replace(/&amp;/g, "&")
      .trim();

    const baseId = slugify(plainTitle) || `section-${toc.length + 1}`;
    const count = (idCounts.get(baseId) ?? 0) + 1;
    idCounts.set(baseId, count);

    const finalId = count > 1 ? `${baseId}-${count}` : baseId;

    toc.push({
      id: finalId,
      title: plainTitle,
      level: Number(level),
    });

    return `<h${level} id="${finalId}">${rawTitle}</h${level}>`;
  }
);

const relatedTools = [
  {
    title: "Xbox Gamertag Generator",
    description: "Generate unique Xbox gamertags instantly with our AI-powered tool.",
    href: "/",
  },
  {
    title: "Availability Checker",
    description: "Check if your desired gamertag is still available before someone else takes it.",
    href: "/gamertag-checker",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  url: articleUrl,
  description: post.excerpt,
  author: {
    "@type": "Organization",
    name: "Xbox Gamertag Generator",
  },
};
---

<MainLayout
  title={`${post.title} | Xbox Gamertag Guide`}
  description={post.excerpt}
  keywords={`${post.title.toLowerCase()}, xbox gamertag guide, gaming tips, xbox naming`}
  canonical={articleUrl}
  ogType="article"
  {schema}
>
  <Header />

  <div class="min-h-screen bg-gray-100 font-ui">
    <!-- Hero Section -->
    <section class="pt-5 pb-5 sm:pt-6 sm:pb-6 md:pt-8 md:pb-8 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-lg p-8 sm:p-12 text-center shadow-sm">
          <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-gray-900">
            {post.title}
          </h1>

          <p class="text-base sm:text-lg md:text-xl text-gray-700 mb-6 max-w-3xl mx-auto">
            {post.excerpt}
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 text-sm text-gray-600">
            <div class="flex items-center gap-2">
              <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A10.966 10.966 0 0112 15c2.125 0 4.109.602 5.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>By Xbox Gamertag Generator</span>
            </div>

            <div class="flex items-center gap-2">
              <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{post.readTime}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Image -->
    <section class="px-4 sm:px-6 lg:px-8 -mt-8 relative z-10 pt-[20px] pb-[35px] bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="relative aspect-video rounded-xl overflow-hidden shadow-lg bg-gray-200">
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center">
              <div class="text-4xl mb-2">🎮</div>
              <p class="text-sm text-gray-500 font-medium">Article Image Placeholder</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content with Right Ad -->
    <div class="bg-gray-100 min-h-screen pt-2 pb-0">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-0">
        <div class="flex flex-col lg:flex-row gap-8">
          <!-- Main Article Content -->
          <main class="flex-1 max-w-none order-1 lg:order-1">
            <!-- Mobile & Tablet Ad Banner -->
            <div class="lg:hidden">
              <div class="bg-gray-100 rounded-lg p-4 text-center border-2 border-dashed border-gray-300 mb-6 mt-2">
                <p class="text-xs text-gray-500">Advertisement</p>
                <div class="h-32 bg-gray-200 rounded mt-2"></div>
              </div>
            </div>

            <div class="bg-white rounded-t-lg shadow-sm pb-12 min-h-screen my-0 py-[15px]">
              <article class="p-6 sm:p-8">
                {toc.length > 0 && (
                  <div class="mb-8">
                    <details class="bg-white rounded-lg shadow-sm border border-gray-200" open>
                      <summary class="list-none p-5 border-b border-gray-100 cursor-pointer">
                        <div class="w-full flex items-center justify-between text-lg font-semibold text-gray-800 hover:text-brand transition-colors">
                          <div class="flex items-center gap-2">
                            <svg class="h-5 w-5 text-brand" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                            </svg>
                            Table of Contents
                          </div>

                          <svg class="h-5 w-5 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                          </svg>
                        </div>
                      </summary>

                      <nav class="p-5">
                        <ul class="space-y-2">
                          {toc.map((item) => (
                            <li>
                              <a
                                href={`#${item.id}`}
                                class:list={[
                                  "block text-sm transition-colors hover:text-brand",
                                  item.level === 3
                                    ? "pl-4 text-gray-600"
                                    : "text-gray-700 font-medium"
                                ]}
                              >
                                {item.title}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </nav>
                    </details>
                  </div>
                )}

                <div
                  class="
                    prose prose-lg max-w-none
                    prose-p:text-gray-700 prose-p:leading-8 prose-p:mb-5
                    prose-headings:font-ui
                    prose-h2:text-brand prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-10 prose-h2:mb-4
                    prose-h3:text-gray-800 prose-h3:text-xl prose-h3:font-bold prose-h3:mt-8 prose-h3:mb-3
                    prose-strong:text-gray-900 prose-strong:font-semibold
                    prose-a:text-brand prose-a:no-underline hover:prose-a:underline
                    prose-li:text-gray-700
                    prose-ul:my-4 prose-ol:my-4
                    prose-blockquote:border-l-[#00D02B] prose-blockquote:text-gray-600
                    prose-code:text-[#00A021] prose-code:bg-gray-100 prose-code:rounded prose-code:px-1.5 prose-code:py-0.5
                    prose-pre:bg-gray-900 prose-pre:text-gray-100 prose-pre:border prose-pre:border-gray-700
                    prose-hr:border-gray-200
                  "
                  set:html={contentWithIds}
                />
              </article>

              <!-- Call to Action -->
              <div class="bg-brand rounded-lg p-6 text-center text-white m-6">
                <h3 class="text-xl font-bold mb-2">Ready to Create Your Gamertag?</h3>
                <p class="mb-4">
                  Use our free Xbox Gamertag Generator to find the perfect name for your gaming identity.
                </p>
                <a
                  href="/"
                  class="inline-flex items-center justify-center bg-white text-brand hover:bg-gray-100 font-semibold px-6 py-3 rounded-lg transition-colors"
                >
                  Try Generator Now
                </a>
              </div>

              <!-- Related Posts -->
              {relatedPosts.length > 0 && (
                <section class="p-6 sm:p-8 border-t border-gray-200">
                  <h2 class="text-2xl font-bold text-gray-800 mb-6">Related Posts</h2>

                  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    {relatedPosts.map((relatedPost) => (
                      <a
                        href={`/${relatedPost.slug}`}
                        class="bg-gray-50 rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-shadow group"
                      >
                        <div class="h-40 bg-gray-200 flex items-center justify-center">
                          <span class="text-gray-500 text-sm">Gaming Image Placeholder</span>
                        </div>

                        <div class="p-4">
                          <h3 class="font-semibold text-gray-800 mb-2 group-hover:text-brand transition-colors">
                            {relatedPost.title}
                          </h3>
                          <p class="text-sm text-gray-600">{relatedPost.readTime}</p>
                        </div>
                      </a>
                    ))}
                  </div>
                </section>
              )}

              <!-- Ad Banner after Related Posts -->
              <div class="m-6 bg-gray-100 rounded-lg p-6 text-center border-2 border-dashed border-gray-300">
                <p class="text-sm text-gray-500 mb-2">Advertisement</p>
                <div class="h-32 bg-gray-200 rounded"></div>
              </div>

              <!-- Related Tools -->
              <section class="p-6 sm:p-8 border-t border-gray-200">
                <h2 class="text-2xl font-bold text-gray-800 mb-6">Related Tools</h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  {relatedTools.map((tool) => (
                    <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
                      <h3 class="text-xl font-bold mb-2 text-brand">{tool.title}</h3>
                      <p class="text-gray-600 mb-4">{tool.description}</p>
                      <a
                        href={tool.href}
                        class="inline-flex items-center justify-center bg-brand hover:bg-brand-light text-white font-semibold px-5 py-3 rounded-lg transition-colors"
                      >
                        Go to Tool
                      </a>
                    </div>
                  ))}
                </div>
              </section>

              <!-- Bottom Ad Space -->
              <div class="mx-6 mt-6 mb-0 bg-gray-100 rounded-lg p-6 text-center border-2 border-dashed border-gray-300">
                <p class="text-sm text-gray-500 mb-2">Advertisement</p>
                <div class="h-32 bg-gray-200 rounded"></div>
              </div>
            </div>
          </main>

          <!-- Sticky Ad Space - Desktop Sidebar on Right -->
          <aside class="hidden lg:block lg:w-64 flex-shrink-0 order-2 lg:order-2">
            <div class="sticky top-4 space-y-6 transition-all duration-200 my-0 py-[50px]">
              <div class="bg-gray-100 rounded-lg p-4 text-center border-2 border-dashed border-gray-300">
                <p class="text-xs text-gray-500">Advertisement</p>
                <div class="h-64 bg-gray-200 rounded mt-2"></div>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </div>
</MainLayout>