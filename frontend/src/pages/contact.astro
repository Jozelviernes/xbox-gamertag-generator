---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Xbox Gamertag Generator",
  "url": "https://xboxgamertaggenerator.com/contact",
};
---

<MainLayout
  title="Contact Us | Xbox Gamertag Generator"
  description="Questions? Suggestions? We're here. Contact Xbox Gamertag Generator for support, ideas, or feedback."
  keywords="contact xbox gamertag generator, support, feedback, gaming tool help"
  {schema}
>
  <Header />

  <div class="min-h-screen bg-[#000000]">

    <!-- ── Hero ── -->
    <section class="bg-[#000000] relative overflow-hidden flex items-center min-h-[360px]">
      <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 70% 55% at 50% 0%, rgba(0,208,43,0.10) 0%, transparent 65%);"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-8 lg:px-12 py-16 text-center w-full">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-sm mb-6">
          <span class="font-[Rajdhani] text-[10px] font-bold tracking-[3px] uppercase text-[#00D02B]">Get in Touch</span>
        </div>
        <h1 class="font-[Orbitron] text-4xl md:text-5xl font-black text-white mb-4 leading-tight">
          Contact <span class="text-[#00D02B]">Us</span>
        </h1>
        <p class="font-[Rajdhani] text-xl md:text-2xl text-[#94A3B8] mb-4 font-semibold">
          Questions? Suggestions? We're here.
        </p>
        <p class="font-[Rajdhani] text-base text-[#4B5563] max-w-xl mx-auto leading-relaxed">
          We love hearing from fellow gamers. Whether you have a question about a tool, need support, or want to share an idea, reach out below.
        </p>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, #1F2937 20%, #00D02B 50%, #1F2937 80%, transparent);"></div>
    </section>

    <!-- ── Contact Form — White section ── -->
    <section class="bg-[#ffffff] py-16 border-t border-[#E2E8F0]">
      <div class="max-w-2xl mx-auto px-4 sm:px-6">

        <div class="text-center mb-10">
          <h2 class="font-[Orbitron] text-xl font-bold text-[#050505] mb-2">Send us a Message</h2>
          <p class="font-[Rajdhani] text-sm text-[#64748B]">We'll get back to you as soon as possible.</p>
        </div>

        <form id="contactForm" class="bg-white border border-[#E2E8F0] rounded-xl p-6 md:p-8 shadow-[0_4px_24px_-8px_rgba(0,0,0,0.1)]">
          <div class="space-y-5">

            <div>
              <label for="name" class="font-[Rajdhani] text-xs font-bold tracking-[2px] uppercase text-[#64748B] block mb-2">Name</label>
              <input
                id="name"
                name="name"
                type="text"
                placeholder="Your name"
                class="w-full h-11 px-4 bg-[#F8FAFC] border border-[#E2E8F0] rounded-lg text-[#050505] placeholder-[#CBD5E1] font-[Rajdhani] text-sm font-semibold focus:outline-none focus:border-[#00D02B] focus:ring-2 focus:ring-[#00D02B]/12 transition-colors"
                required
              />
            </div>

            <div>
              <label for="email" class="font-[Rajdhani] text-xs font-bold tracking-[2px] uppercase text-[#64748B] block mb-2">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                placeholder="your@email.com"
                class="w-full h-11 px-4 bg-[#F8FAFC] border border-[#E2E8F0] rounded-lg text-[#050505] placeholder-[#CBD5E1] font-[Rajdhani] text-sm font-semibold focus:outline-none focus:border-[#00D02B] focus:ring-2 focus:ring-[#00D02B]/12 transition-colors"
                required
              />
            </div>

            <div>
              <label for="message" class="font-[Rajdhani] text-xs font-bold tracking-[2px] uppercase text-[#64748B] block mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                rows="6"
                placeholder="Tell us what's on your mind..."
                class="w-full px-4 py-3 bg-[#F8FAFC] border border-[#E2E8F0] rounded-lg text-[#050505] placeholder-[#CBD5E1] font-[Rajdhani] text-sm font-semibold resize-none focus:outline-none focus:border-[#00D02B] focus:ring-2 focus:ring-[#00D02B]/12 transition-colors"
                required
              ></textarea>
            </div>

            <button
              id="submitBtn"
              type="submit"
              class="w-full h-12 bg-[#00D02B] hover:bg-[#00e830] text-black font-[Rajdhani] font-bold text-sm uppercase tracking-widest rounded-lg transition-colors duration-200 inline-flex items-center justify-center gap-2"
            >
              <span id="sendIcon" class="inline-flex items-center">
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L15 22L11 13L2 9L22 2Z" />
                </svg>
              </span>
              <span id="submitText">Send Message</span>
            </button>

          </div>
        </form>
      </div>
    </section>

   <!-- ── Quick Help — White section ── -->
<section class="bg-[#F8FAFC] py-14 border-t border-[#E2E8F0]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">

    <div class="text-center mb-10">
      <h2 class="font-[Orbitron] text-xl font-bold text-[#050505] mb-2">Quick Help &amp; Resources</h2>
      <p class="text-sm text-[#64748B]">Find what you're looking for faster.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-4">

      <a href="/" class="group bg-white border border-[#E2E8F0] rounded-xl p-6 text-center transition-all duration-200 hover:border-[#00D02B]/50 hover:-translate-y-0.5">
        <div class="w-10 h-10 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:bg-[#00D02B]/15 transition-colors duration-200">
          <svg class="text-[#00D02B] w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <circle cx="12" cy="12" r="9" stroke-width="2"></circle>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l2 2m4-2l-2 2m-3 2l3 3 3-3" />
          </svg>
        </div>
        <h3 class=" text-xs font-bold text-[#050505] mb-1 group-hover:text-[#00D02B] transition-colors duration-200">Xbox Gamertag Generator</h3>
        <p class="text-xs text-[#64748B]">Generate unique Xbox gamertags</p>
      </a>

      <a href="/tools" class="group bg-white border border-[#E2E8F0] rounded-xl p-6 text-center transition-all duration-200 hover:border-[#00D02B]/50 hover:-translate-y-0.5">
        <div class="w-10 h-10 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:bg-[#00D02B]/15 transition-colors duration-200">
          <svg class="text-[#00D02B] w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v8m-4-4h8" />
            <circle cx="12" cy="12" r="9" stroke-width="2"></circle>
          </svg>
        </div>
        <h3 class=" text-xs font-bold text-[#050505] mb-1 group-hover:text-[#00D02B] transition-colors duration-200">Other Tools</h3>
        <p class="text-xs text-[#64748B]">Explore all our gaming tools</p>
      </a>

      <a href="/blog" class="group bg-white border border-[#E2E8F0] rounded-xl p-6 text-center transition-all duration-200 hover:border-[#00D02B]/50 hover:-translate-y-0.5">
        <div class="w-10 h-10 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:bg-[#00D02B]/15 transition-colors duration-200">
          <svg class="text-[#00D02B] w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.5 17H20V5H6.5A2.5 2.5 0 0 0 4 7.5v12" />
          </svg>
        </div>
        <h3 class=" text-xs font-bold text-[#050505] mb-1 group-hover:text-[#00D02B] transition-colors duration-200">Guides &amp; Resources</h3>
        <p class="text-xs text-[#64748B]">Helpful guides and tutorials</p>
      </a>

    </div>
  </div>
</section>

  </div>

  <script>
    const form = document.getElementById("contactForm");
    const submitBtn = document.getElementById("submitBtn");
    const submitText = document.getElementById("submitText");
    const sendIcon = document.getElementById("sendIcon");

    if (
      form instanceof HTMLFormElement &&
      submitBtn instanceof HTMLButtonElement &&
      submitText instanceof HTMLElement &&
      sendIcon instanceof HTMLElement
    ) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        submitText.textContent = "Sending...";
        sendIcon.innerHTML = `<svg class="h-4 w-4 animate-pulse" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L15 22L11 13L2 9L22 2Z" /></svg>`;
        await new Promise((resolve) => setTimeout(resolve, 1000));
        form.reset();
        submitBtn.disabled = false;
        submitText.textContent = "Send Message";
        sendIcon.innerHTML = `<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L15 22L11 13L2 9L22 2Z" /></svg>`;
        alert("Message Sent! Thanks for reaching out. We'll get back to you soon!");
      });
    }
  </script>
</MainLayout>