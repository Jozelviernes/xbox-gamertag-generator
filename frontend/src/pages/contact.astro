---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Xbox Gamertag Generator",
  "url": "https://xboxgamertaggenerator.com/contact",
};

const helpLinks = [
  {
    title: "Xbox Gamertag Generator",
    description: "Generate unique Xbox gamertags",
    href: "/",
    icon: `
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <circle cx="12" cy="12" r="9" stroke-width="2"></circle>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l2 2m4-2l-2 2m-3 2l3 3 3-3" />
      </svg>
    `,
  },
  {
    title: "Other Tools",
    description: "Explore all our gaming tools",
    href: "/tools",
    icon: `
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v8m-4-4h8" />
        <circle cx="12" cy="12" r="9" stroke-width="2"></circle>
      </svg>
    `,
  },
  {
    title: "Guides & Resources",
    description: "Helpful guides and tutorials",
    href: "/blog",
    icon: `
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.5 17H20V5H6.5A2.5 2.5 0 0 0 4 7.5v12" />
      </svg>
    `,
  },
];
---

<MainLayout
  title="Contact Us | Xbox Gamertag Generator"
  description="Questions? Suggestions? We're here. Contact Xbox Gamertag Generator for support, ideas, or feedback."
  keywords="contact xbox gamertag generator, support, feedback, gaming tool help"
  {schema}
>
  <Header />

  <div class="min-h-screen bg-[#F3F4F6] text-[#111827] font-ui">
    <!-- Hero -->
    <section class="bg-[#F3F4F6] py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-8 sm:px-12 lg:px-16">
        <div class="max-w-4xl mx-auto text-center md:text-left">
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold mb-6 text-[#111827] leading-tight">
            Contact <span class="text-brand">Us</span>
          </h1>

          <h2 class="text-2xl md:text-3xl text-[#6B7280] mb-8 font-medium leading-snug">
            Questions? Suggestions? We&apos;re here.
          </h2>

          <p class="text-lg md:text-xl text-[#374151] leading-relaxed max-w-3xl">
            We love hearing from fellow gamers. Whether you have a question about a tool, need support, or want to share an idea, reach out below.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Form -->
    <section class="py-16 md:py-20 bg-[#E5E7EB]">
      <div class="max-w-5xl mx-auto px-8 sm:px-12 lg:px-16">
        <div class="max-w-3xl mx-auto">
          <div class="text-center md:text-left mb-10">
            <h2 class="text-4xl md:text-5xl font-extrabold mb-4 text-[#111827]">
              Send us a <span class="text-brand">Message</span>
            </h2>
            <p class="text-base md:text-lg text-[#4B5563]">
              We&apos;ll get back to you as soon as possible.
            </p>
          </div>

          <form
            id="contactForm"
            class="bg-white border border-[#E5E7EB] rounded-xl p-6 md:p-8 shadow-lg"
          >
            <div class="space-y-5">
              <div>
                <label for="name" class="block mb-2 text-xs font-bold uppercase tracking-[0.18em] text-[#6B7280]">
                  Name
                </label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  placeholder="Your name"
                  class="w-full h-12 px-4 bg-[#F8FAFC] border border-[#E5E7EB] rounded-lg text-[#111827] placeholder-[#9CA3AF] text-sm md:text-base font-medium focus:outline-none focus:border-[#00D02B] focus:ring-2 focus:ring-[#00D02B]/15 transition-colors"
                  required
                />
              </div>

              <div>
                <label for="email" class="block mb-2 text-xs font-bold uppercase tracking-[0.18em] text-[#6B7280]">
                  Email
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder="your@email.com"
                  class="w-full h-12 px-4 bg-[#F8FAFC] border border-[#E5E7EB] rounded-lg text-[#111827] placeholder-[#9CA3AF] text-sm md:text-base font-medium focus:outline-none focus:border-[#00D02B] focus:ring-2 focus:ring-[#00D02B]/15 transition-colors"
                  required
                />
              </div>

              <div>
                <label for="message" class="block mb-2 text-xs font-bold uppercase tracking-[0.18em] text-[#6B7280]">
                  Message
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="6"
                  placeholder="Tell us what's on your mind..."
                  class="w-full px-4 py-3 bg-[#F8FAFC] border border-[#E5E7EB] rounded-lg text-[#111827] placeholder-[#9CA3AF] text-sm md:text-base font-medium resize-none focus:outline-none focus:border-[#00D02B] focus:ring-2 focus:ring-[#00D02B]/15 transition-colors"
                  required
                ></textarea>
              </div>

              <button
                id="submitBtn"
                type="submit"
                class="w-full bg-brand hover:bg-brand-light text-white py-3.5 px-6 rounded-lg font-semibold transition-colors duration-200 inline-flex items-center justify-center gap-2"
              >
                <span id="sendIcon" class="inline-flex items-center">
                  <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L15 22L11 13L2 9L22 2Z" />
                  </svg>
                </span>
                <span id="submitText">Send Message</span>
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- Quick Help -->
    <section class="py-16 md:py-20 bg-[#F3F4F6]">
      <div class="max-w-5xl mx-auto px-8 sm:px-12 lg:px-16">
        <div class="max-w-4xl mx-auto">
          <div class="text-center md:text-left mb-10">
            <h2 class="text-4xl md:text-5xl font-extrabold mb-4 text-[#111827]">
              Quick Help &amp; <span class="text-brand">Resources</span>
            </h2>
            <p class="text-base md:text-lg text-[#4B5563]">
              Find what you&apos;re looking for faster.
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-6">
            {helpLinks.map((item) => (
              <a
                href={item.href}
                class="group bg-white rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-200 flex flex-col h-full text-center"
              >
                <div class="text-brand mx-auto mb-4 flex justify-center" set:html={item.icon}></div>

                <h3 class="text-lg font-semibold mb-2 text-gray-800 group-hover:text-brand transition-colors">
                  {item.title}
                </h3>

                <p class="text-sm text-gray-600 leading-7 flex-1">
                  {item.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    const form = document.getElementById("contactForm");
    const submitBtn = document.getElementById("submitBtn");
    const submitText = document.getElementById("submitText");
    const sendIcon = document.getElementById("sendIcon");

    if (
      form instanceof HTMLFormElement &&
      submitBtn instanceof HTMLButtonElement &&
      submitText instanceof HTMLElement &&
      sendIcon instanceof HTMLElement
    ) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        submitText.textContent = "Sending...";
        sendIcon.innerHTML = `<svg class="h-4 w-4 animate-pulse" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L15 22L11 13L2 9L22 2Z" /></svg>`;
        await new Promise((resolve) => setTimeout(resolve, 1000));
        form.reset();
        submitBtn.disabled = false;
        submitText.textContent = "Send Message";
        sendIcon.innerHTML = `<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L15 22L11 13L2 9L22 2Z" /></svg>`;
        alert("Message Sent! Thanks for reaching out. We'll get back to you soon!");
      });
    }
  </script>
</MainLayout>