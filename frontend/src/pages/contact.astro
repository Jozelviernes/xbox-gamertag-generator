---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
---

<MainLayout
  title="Contact Us - Xbox Gamertag Generator"
  description="Questions? Suggestions? We're here. Contact Xbox Gamertag Generator for support, ideas, or feedback."
>
  <Header />

  <div class="min-h-screen bg-white">
    <!-- Hero Section -->
    <section class="h-[400px] flex items-center justify-center bg-gradient-to-br from-gray-200 to-gray-300">
      <div class="container mx-auto px-6 text-center md:text-left max-w-4xl">
        <h1 class="text-4xl md:text-5xl font-bebas mb-4 text-gray-800">
          Contact <span class="text-xbox-green">Us</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-600 mb-6 font-medium">
          Questions? Suggestions? We're here.
        </p>
        <p class="text-lg text-gray-500 max-w-2xl">
          We love hearing from fellow gamers. Whether you have a question about a tool, need support, or want to share an idea, reach out below.
        </p>
      </div>
    </section>

    <!-- Contact Form Section -->
    <section class="py-16 bg-gray-200">
      <div class="container mx-auto px-6">
        <div class="max-w-2xl mx-auto">
          <form id="contactForm" class="bg-white rounded-xl shadow-2xl p-8">
            <div class="space-y-6">
              <div>
                <label for="name" class="block text-sm font-medium mb-2 text-gray-700">Name</label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  placeholder="Your name"
                  class="w-full h-12 px-4 rounded-md border border-gray-300 bg-white text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-xbox-green focus:border-xbox-green transition"
                  required
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium mb-2 text-gray-700">Email</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder="your@email.com"
                  class="w-full h-12 px-4 rounded-md border border-gray-300 bg-white text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-xbox-green focus:border-xbox-green transition"
                  required
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-medium mb-2 text-gray-700">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="6"
                  placeholder="Tell us what's on your mind..."
                  class="w-full px-4 py-3 rounded-md border border-gray-300 bg-white text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-xbox-green focus:border-xbox-green resize-none transition"
                  required
                ></textarea>
              </div>

              <button
                id="submitBtn"
                type="submit"
                class="w-full h-12 bg-xbox-green hover:bg-xbox-green/90 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 inline-flex items-center justify-center"
              >
                <span id="sendIcon" class="mr-2 inline-flex items-center">
                  <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L15 22L11 13L2 9L22 2Z" />
                  </svg>
                </span>
                <span id="submitText">Send Message</span>
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- Quick Help & Resources Section -->
    <section class="py-12 bg-gray-300">
      <div class="container mx-auto px-6">
        <h2 class="text-2xl font-bebas text-center mb-8 text-gray-800">Quick Help & Resources</h2>
        <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
          <a href="/" class="bg-white p-6 rounded-lg hover:bg-gray-50 hover:shadow-lg hover:scale-105 transition-all duration-300 text-center shadow-md group">
            <svg class="text-xbox-green mb-3 mx-auto h-8 w-8 group-hover:scale-110 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <circle cx="12" cy="12" r="9" stroke-width="2"></circle>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l2 2m4-2l-2 2m-3 2l3 3 3-3" />
            </svg>
            <h3 class="font-semibold mb-2 text-gray-800 group-hover:text-xbox-green transition-colors duration-300">Xbox Gamertag Generator</h3>
            <p class="text-gray-600 text-sm group-hover:text-gray-700 transition-colors duration-300">Generate unique Xbox gamertags</p>
          </a>

          <a href="/tools" class="bg-white p-6 rounded-lg hover:bg-gray-50 hover:shadow-lg hover:scale-105 transition-all duration-300 text-center shadow-md group">
            <svg class="text-xbox-green mb-3 mx-auto h-8 w-8 group-hover:scale-110 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v8m-4-4h8" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h0m14 0h0" />
              <circle cx="12" cy="12" r="9" stroke-width="2"></circle>
            </svg>
            <h3 class="font-semibold mb-2 text-gray-800 group-hover:text-xbox-green transition-colors duration-300">Other Tools</h3>
            <p class="text-gray-600 text-sm group-hover:text-gray-700 transition-colors duration-300">Explore all our gaming tools</p>
          </a>

          <a href="/blog" class="bg-white p-6 rounded-lg hover:bg-gray-50 hover:shadow-lg hover:scale-105 transition-all duration-300 text-center shadow-md group">
            <svg class="text-xbox-green mb-3 mx-auto h-8 w-8 group-hover:scale-110 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.5 17H20V5H6.5A2.5 2.5 0 0 0 4 7.5v12" />
            </svg>
            <h3 class="font-semibold mb-2 text-gray-800 group-hover:text-xbox-green transition-colors duration-300">Guides & Resources</h3>
            <p class="text-gray-600 text-sm group-hover:text-gray-700 transition-colors duration-300">Helpful guides and tutorials</p>
          </a>
        </div>
      </div>
    </section>
  </div>

  <script>
    const form = document.getElementById("contactForm");
    const submitBtn = document.getElementById("submitBtn");
    const submitText = document.getElementById("submitText");
    const sendIcon = document.getElementById("sendIcon");

    if (
      form instanceof HTMLFormElement &&
      submitBtn instanceof HTMLButtonElement &&
      submitText instanceof HTMLElement &&
      sendIcon instanceof HTMLElement
    ) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        submitBtn.disabled = true;
        submitText.textContent = "Sending...";
        sendIcon.innerHTML = `
          <svg class="h-4 w-4 animate-pulse" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L15 22L11 13L2 9L22 2Z" />
          </svg>
        `;

        await new Promise((resolve) => setTimeout(resolve, 1000));

        form.reset();
        submitBtn.disabled = false;
        submitText.textContent = "Send Message";
        sendIcon.innerHTML = `
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L15 22L11 13L2 9L22 2Z" />
          </svg>
        `;

        alert("Message Sent! Thanks for reaching out. We'll get back to you soon!");
      });
    }
  </script>
</MainLayout>