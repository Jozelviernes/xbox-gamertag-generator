---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/layout/Header.astro';
---

<MainLayout
  title="Gamertag Checker — Is Your Xbox Tag Available?"
  description="Check if an Xbox gamertag is taken or likely available using live Xbox data."
>
  <Header />

  <div class="min-h-screen bg-background text-foreground">

    <!-- ── Hero ── -->
    <section class="bg-background relative overflow-hidden py-14 md:py-20">
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(ellipse 70% 55% at 50% 0%, rgba(0,208,43,0.10) 0%, transparent 65%);"
      ></div>

      <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-8 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-brand-dim border border-green rounded-sm mb-6">
          <span class="label-green">Free Tool</span>
        </div>

        <h1 class="heading-hero text-3xl md:text-4xl text-foreground mb-4">
          Xbox Gamertag <span class="text-brand">Checker</span>
        </h1>

        <p class="text-foreground-muted text-sm md:text-base max-w-xl mx-auto leading-relaxed">
          Enter an Xbox gamertag to see if it is already taken or still likely available.
        </p>
      </div>

      <div
        class="absolute bottom-0 left-0 right-0 h-px"
        style="background: linear-gradient(90deg, transparent, #1F2937 20%, #00D02B 50%, #1F2937 80%, transparent);"
      ></div>
    </section>

    <!-- ── Tool ── -->
    <section class="section-dark py-10">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 space-y-5">

        <!-- Input Card -->
        <div class="game-card p-6 shadow-card">
          <label
            for="gamertag-input"
            class="label-mono block mb-3"
          >
            Enter Xbox Gamertag
          </label>

          <div class="flex flex-col sm:flex-row gap-3">
            <input
              id="gamertag-input"
              type="text"
              maxlength="15"
              placeholder="e.g. MajorNelson"
              autocomplete="off"
              spellcheck="false"
              class="input-dark flex-1"
            />
            <button
              id="check-btn"
              class="btn-primary whitespace-nowrap disabled:opacity-40 disabled:cursor-not-allowed"
            >
              Check Tag
            </button>
          </div>

          <p class="text-foreground-subtle text-xs mt-2">
            Xbox gamertags are 1–15 characters. Results are based on live Xbox data.
          </p>
          <p class="text-foreground-subtle text-xs mt-1 leading-relaxed">
            “Likely available” means no matching public Xbox profile was found. It may still be reserved by Microsoft.
          </p>
        </div>

        <!-- Loading -->
        <div id="loading" class="hidden text-center py-12">
          <div
            class="inline-block w-8 h-8 rounded-full animate-spin mb-4"
            style="border: 2px solid #1F2937; border-top-color: #00D02B;"
          ></div>
          <p class="text-sm text-foreground-muted tracking-wide">Checking with Xbox Live...</p>
        </div>

        <!-- Result -->
        <div id="result" class="hidden">
          <div
            id="result-inner"
            class="game-card p-6 shadow-card"
          ></div>
        </div>

        <!-- Info note -->
        <p class="text-center text-xs text-foreground-subtle px-4 leading-relaxed">
          Results show whether a tag is <strong class="text-foreground">in use</strong> on Xbox Live.
          “Likely available” means no profile was found — it may still be reserved by Microsoft.
        </p>

        <!-- Ad slot -->
        <div class="mt-10 max-w-2xl mx-auto rounded-lg px-6 py-10 text-center border border-dashed border-default bg-background-surface">
          <p class="label-mono text-foreground-subtle mb-3">Advertisement</p>
          <div class="h-20 md:h-28 rounded bg-background-alt"></div>
        </div>

      </div>
    </section>
  </div>
</MainLayout>

<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';

  const input    = document.getElementById('gamertag-input') as HTMLInputElement;
  const btn      = document.getElementById('check-btn') as HTMLButtonElement;
  const result   = document.getElementById('result')!;
  const inner    = document.getElementById('result-inner')!;
  const loading  = document.getElementById('loading')!;

  async function checkTag() {
    const tag = input.value.trim();
    if (!tag) return;

    result.classList.add('hidden');
    loading.classList.remove('hidden');
    btn.disabled = true;

    try {
      const res  = await fetch(`${API_BASE}/api/xbox/gametag/check`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body:    JSON.stringify({ gamertag: tag }),
      });
      const data = await res.json();

      loading.classList.add('hidden');
      result.classList.remove('hidden');

    if (data.error) {
  inner.innerHTML = errorHTML(data.message ?? 'Could not connect to Xbox API. Please try again.');
  return;
}

      const isAvailable = data.available;
      inner.innerHTML   = isAvailable ? availableHTML(data.gamertag) : takenHTML(data.gamertag);

    } catch {
      loading.classList.add('hidden');
      result.classList.remove('hidden');
      inner.innerHTML = errorHTML('Network error. Please check your connection.');
    } finally {
      btn.disabled = false;
    }
  }

  function availableHTML(tag: string) {
    return `
      <div class="flex items-start gap-4">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-dim border border-green shrink-0">
          <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <div>
          <p class="font-display text-foreground font-bold text-lg">${escHtml(tag)}</p>
          <p class="label-green mt-1">Likely Available</p>
          <p class="text-foreground-muted text-sm mt-1">
            No Xbox profile matched this gamertag. It may be free to claim.
          </p>
        </div>
      </div>
    `;
  }

  function takenHTML(tag: string) {
    return `
      <div class="flex items-start gap-4">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-[rgba(239,68,68,0.08)] border border-[rgba(239,68,68,0.30)] shrink-0">
          <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </div>
        <div>
          <p class="font-display text-foreground font-bold text-lg">${escHtml(tag)}</p>
          <p class="label-mono mt-1 text-red-400">Taken</p>
          <p class="text-foreground-muted text-sm mt-1">
            This gamertag is already registered to an Xbox account.
          </p>
        </div>
      </div>
    `;
  }

  function errorHTML(msg: string) {
    return `
      <div class="flex items-start gap-4">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-[rgba(245,158,11,0.08)] border border-[rgba(245,158,11,0.30)] shrink-0">
          <svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
          </svg>
        </div>
        <div>
          <p class="font-bold text-yellow-400">Error</p>
          <p class="text-foreground-muted text-sm mt-1">${escHtml(msg)}</p>
        </div>
      </div>
    `;
  }

  function escHtml(str: string) {
    return str.replace(/[&<>"']/g, c =>
      ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!));
  }

  btn.addEventListener('click', checkTag);
  input.addEventListener('keydown', e => { if (e.key === 'Enter') checkTag(); });
</script>