---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Terms and Conditions",
  "url": "https://xboxgamertaggenerator.com/terms-and-conditions",
  "description": "Terms and Conditions for Xbox Gamertag Generator.",
};
---

<MainLayout
  title="Terms and Conditions"
  description="Read the terms and conditions for using Xbox Gamertag Generator and its tools."
  keywords="terms and conditions, xbox gamertag generator terms"
  {schema}
>
  <Header />

  <div class="min-h-screen bg-[#F8FAFC]">

    <!-- Hero -->
    <section class="bg-white border-b border-[#E2E8F0] py-14 md:py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-8 lg:px-12 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-sm mb-6">
          <span class="text-[10px] font-bold tracking-[3px] uppercase text-[#00D02B]">Legal</span>
        </div>
        <h1 class="font-display text-3xl md:text-4xl font-black text-[#050505] mb-4 leading-tight">
          Terms &amp; <span class="text-[#00D02B]">Conditions</span>
        </h1>
        <p class="text-base md:text-lg text-[#64748B] max-w-2xl mx-auto leading-relaxed">
          Please read these terms carefully before using Xbox Gamertag Generator.
        </p>
      </div>
    </section>

    <!-- Content -->
    <section class="py-14 md:py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-12">

        <p class="text-sm text-[#94A3B8] mb-10">Effective Date: April 2026</p>

        <p class="text-[17px] leading-8 text-[#64748B] mb-12">
          By accessing and using https://xboxgamertaggenerator.com, you agree to the following terms.
        </p>

        <div class="space-y-10">

          {[
            {
              number: "1",
              title: "Use of the Website",
              content: "This website provides free tools for generating and analyzing Xbox gamertags. You agree to use the site only for lawful purposes.",
            },
            {
              number: "2",
              title: "No Affiliation with Microsoft",
              content: "This website is not affiliated with, endorsed by, or sponsored by Microsoft or Xbox. All trademarks belong to their respective owners.",
            },
          ].map((section) => (
            <div class="bg-white border border-[#E2E8F0] mb-8  rounded-xl p-6 md:p-8">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-7 h-7 bg-[#00D02B] rounded flex items-center justify-center flex-shrink-0">
                  <span class="text-black text-xs font-bold">{section.number}</span>
                </div>
                <h2 class="font-display text-lg md:text-xl font-bold text-[#050505]">{section.title}</h2>
              </div>
              <p class="text-[16px] leading-8 text-[#64748B]">{section.content}</p>
            </div>
          ))}

          <!-- Section 3 with list -->
          <div class="bg-white border border-[#E2E8F0] rounded-xl p-6 md:p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-7 h-7 bg-[#00D02B] rounded flex items-center justify-center flex-shrink-0">
                <span class="text-black text-xs font-bold">3</span>
              </div>
              <h2 class="font-display text-lg md:text-xl font-bold text-[#050505]">Tool Accuracy Disclaimer</h2>
            </div>
            <p class="text-[16px] leading-8 text-[#64748B] mb-4">
              All tools, including gamertag generators and price estimators, are provided for
              informational and entertainment purposes only. We do not guarantee:
            </p>
            <ul class="space-y-2 pl-1">
              {[
                "Accuracy of generated names",
                "Availability of gamertags",
                "Actual market value of gamertags",
              ].map((item) => (
                <li class="flex items-start gap-3 text-[16px] leading-7 text-[#64748B]">
                  <div class="w-1.5 h-1.5 bg-[#00D02B] rounded-full mt-2.5 flex-shrink-0"></div>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          {[
            {
              number: "4",
              title: "Intellectual Property",
              content: "All content on this website, including design, text, tools, and code, is owned by us unless otherwise stated. You may not copy, reproduce, or distribute any content without permission.",
            },
            {
              number: "5",
              title: "User Responsibility",
              content: "You are responsible for how you use the generated gamertags and tools. We are not liable for username conflicts, Xbox policy violations, or misuse of generated content.",
            },
            {
              number: "6",
              title: "Limitation of Liability",
              content: "We are not responsible for any damages resulting from the use or inability to use the website, inaccuracies in the tools, or issues caused by third-party services or links.",
            },
            {
              number: "7",
              title: "Third-Party Links",
              content: "Our website may include links to third-party websites. We are not responsible for their content, services, or policies.",
            },
            {
              number: "8",
              title: "Modifications",
              content: "We reserve the right to update or change these terms at any time without prior notice. Continued use of the website means you accept those changes.",
            },
            {
              number: "9",
              title: "Termination",
              content: "We may restrict or terminate access to the website if users violate these terms.",
            },
          ].map((section) => (
            <div class="bg-white border border-[#E2E8F0] rounded-xl mb-8 p-6 md:p-8">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-7 h-7 bg-[#00D02B] rounded flex items-center justify-center flex-shrink-0">
                  <span class="text-black text-xs font-bold">{section.number}</span>
                </div>
                <h2 class="font-display text-lg md:text-xl font-bold text-[#050505]">{section.title}</h2>
              </div>
              <p class="text-[16px] leading-8 text-[#64748B]">{section.content}</p>
            </div>
          ))}

          <!-- Contact -->
          <div class="bg-white border-l-4 border-l-[#00D02B] border border-[#E2E8F0] rounded-xl p-6 md:p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-7 h-7 bg-[#00D02B] rounded flex items-center justify-center flex-shrink-0">
                <span class="text-black text-xs font-bold">10</span>
              </div>
              <h2 class="font-display text-lg md:text-xl font-bold text-[#050505]">Contact</h2>
            </div>
            <p class="text-[16px] leading-8 text-[#64748B] mb-3">
              For any questions regarding these Terms, contact:
            </p>
            <p class="text-[16px] font-bold text-[#050505]">xboxgamegenerator@gmail.com</p>
          </div>

        </div>
      </div>
    </section>

  </div>
</MainLayout>