---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";

type IconKey =
  | "gamepad"
  | "search"
  | "chart"
  | "download"
  | "dollar"
  | "trophy"
  | "idcard"
  | "sparkles";

type Tool = {
  id: string;
  title: string;
  description: string;
  slug: string;
  available: boolean;
  href: string;
  icon: IconKey;
};

const tools: Tool[] = [
  {
    id: "1",
    title: "Xbox Gamertag Generator",
    description: "Generate unique, funny, cool, and creative Xbox gamertags instantly.",
    slug: "generator",
    available: true,
    href: "/",
    icon: "gamepad",
  },
  {
    id: "2",
    title: "Xbox Gamertag Availability Checker",
    description: "Check whether an Xbox gamertag is taken or still likely available.",
    slug: "availability-checker",
    available: true,
    href: "/xbox-gamertag-availability-checker",
    icon: "search",
  },
  {
    id: "3",
    title: "Xbox Gamertag Search",
    description: "Look up public Xbox gamer profiles, gamerscore, and profile details by gamertag.",
    slug: "profile-stats-checker",
    available: true,
    href: "/xbox-gamertag-search",
    icon: "chart",
  },
  {
    id: "4",
    title: "Xbox Gamercard Generator",
    description: "Create a custom Xbox gamercard image with your gamertag, avatar, status, and gamerscore.",
    slug: "gamercard-generator",
    available: true,
    href: "/gamercard-generator",
    icon: "idcard",
  },
  {
    id: "5",
    title: "Xbox Gamertag Price Checker",
    description: "Estimate the value of a gamertag based on length, rarity, readability, and overall quality.",
    slug: "price-checker",
    available: true,
    href: "/gamertag-price-checker",
    icon: "dollar",
  },
  {
    id: "6",
    title: "Gamertag Optimizer",
    description: "Shorten, clean, and rewrite weak or messy Xbox gamertags into better options.",
    slug: "gamertag-optimizer",
    available: true,
    href: "/gamertag-optimizer",
    icon: "sparkles",
  }
];
const iconMap: Record<IconKey, string> = {
  gamepad: `<svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 12l-2 5a2 2 0 0 0 3 2l3-2h4l3 2a2 2 0 0 0 3-2l-2-5a6 6 0 0 0-12 0Z" />
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 11v2M7 12h2M16 12h.01M18 10h.01" />
  </svg>`,
  search: `<svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <circle cx="11" cy="11" r="7" stroke-width="1.5"></circle>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 20l-3.5-3.5" />
  </svg>`,
  chart: `<svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 19h16M7 16V9M12 16V5M17 16v-7" />
  </svg>`,
  download: `<svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v11M8 10l4 4 4-4M4 21h16" />
  </svg>`,
  dollar: `<svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v18M16.5 7.5c0-1.9-2-3.5-4.5-3.5S7.5 5.6 7.5 7.5 9.5 11 12 11s4.5 1.6 4.5 3.5S14.5 18 12 18s-4.5-1.6-4.5-3.5" />
  </svg>`,
  trophy: `<svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 4h8v3a4 4 0 0 1-8 0V4ZM6 4H4v2a4 4 0 0 0 4 4M18 4h2v2a4 4 0 0 1-4 4M12 11v4M9 21h6M10 15h4v3h-4z" />
  </svg>`,
  idcard: `<svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <rect x="3" y="5" width="18" height="14" rx="2" ry="2" stroke-width="1.5"></rect>
    <circle cx="9" cy="10" r="2" stroke-width="1.5"></circle>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 16c.8-1.3 2-2 3-2s2.2.7 3 2M14 9h4M14 13h4" />
  </svg>`,
  sparkles: `<svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3Z" />
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 15l.8 2.2L22 18l-2.2.8L19 21l-.8-2.2L16 18l2.2-.8L19 15Z" />
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 14l.8 2.2L8 17l-2.2.8L5 20l-.8-2.2L2 17l2.2-.8L5 14Z" />
  </svg>`,
};

const pageUrl = "https://xboxgamertaggenerator.com/tools";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Xbox Tools",
    "url": pageUrl,
    "description": "Browse free Xbox tools including a gamertag generator, availability checker, gamer profile checker, gamercard generator, optimizer, and more.",
    "inLanguage": "en-US",
    "isPartOf": {
      "@type": "WebSite",
      "name": "Xbox Gamertag Generator",
      "url": "https://xboxgamertaggenerator.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Xbox Tools List",
    "itemListElement": tools.map((tool, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": tool.title,
      "url": `https://xboxgamertaggenerator.com${tool.href}`
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://xboxgamertaggenerator.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Tools",
        "item": pageUrl
      }
    ]
  }
];
---

<MainLayout
  title="Xbox Tools – Gamertag Generator, Checker, Optimizer & More"
  description="Explore free Xbox tools including a gamertag generator, availability checker, gamer profile checker, gamercard generator, optimizer, and more."
  canonical={pageUrl}
  {schema}
>
  <Header />

  <div class="min-h-screen bg-[#F3F4F6] font-ui">
 <!-- Hero -->
<section class="section-dark-alt py-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 2xl:px-16">
    <section class="bg-card py-16 rounded-lg">
      <div class="px-6 text-center">

        <h1 class="font-ui text-3xl md:text-4xl font-bold mb-4 text-foreground">
          Explore All Xbox <span class="text-brand">Tools</span>
        </h1>

        <p class="font-ui text-lg md:text-xl text-foreground-muted mb-4 max-w-3xl mx-auto">
          Everything you need to manage, customize, and level up your Xbox identity.
        </p>

        <p class="font-ui text-base text-foreground-muted max-w-2xl mx-auto">
          From gamertag generators to checkers and profile tools, find the right tool to improve your gaming experience.
        </p>

      </div>
    </section>
  </div>
</section>

    <!-- Tools Grid -->
    <section class="py-16 px-4 md:px-12 lg:px-24 bg-[#F3F4F6]">
      <div class="container mx-auto px-0 sm:px-2 md:px-4">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {tools.map((tool) => (
            <article class="bg-white rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-200 relative flex flex-col h-full">
              {!tool.available && (
                <div class="absolute top-3 right-3 bg-brand text-white text-xs px-2 py-0.5 rounded-full">
                  Coming Soon
                </div>
              )}

              <div class="text-center mb-4">
                <div class="text-brand mx-auto mb-4 flex justify-center" set:html={iconMap[tool.icon]} />
              </div>

              <h3 class="text-xl font-semibold mb-3 text-center text-gray-800">
                {tool.title}
              </h3>

              <p class="text-gray-600 mb-6 text-center leading-7 flex-1">
                {tool.description}
              </p>

              {tool.available ? (
                <a
                  href={tool.href}
                  class="w-full bg-brand hover:bg-brand-light text-white py-3 px-6 rounded-lg font-medium transition-colors duration-200 block text-center mt-auto"
                >
                  Go to Tool
                </a>
              ) : (
                <button
                  disabled
                  class="w-full bg-gray-300 text-gray-500 py-3 px-6 rounded-lg font-medium cursor-not-allowed block text-center mt-auto"
                >
                  Coming Soon
                </button>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-white-subtle py-12">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 text-center">
        <div class="bg-white border border-[#E5E7EB] rounded-lg px-6 py-10 shadow-sm">
          <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-4">
            Ready to find your <span class="text-brand">perfect tag?</span>
          </h2>

          <p class="text-gray-600 mb-8 max-w-2xl mx-auto">
            Start with our gamertag generator and explore all tools for free.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="/"
              class="btn-primary px-8 py-3.5 text-sm inline-flex items-center justify-center gap-2"
            >
              Try the Generator
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>

            <a
              href="/blog"
              class="btn-secondary px-8 py-3.5 text-sm inline-flex items-center justify-center gap-2 !text-[#111827] !border-[#D1D5DB] hover:!border-[#00D02B]/40 hover:!text-[#00B324]"
            >
              Read the Guides
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</MainLayout>