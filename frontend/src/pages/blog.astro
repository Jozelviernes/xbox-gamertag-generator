---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import { blogPosts } from "../data/blogPosts";

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Xbox Gamertag Tips & Guides",
  "url": "https://xboxgamertaggenerator.com/blog",
  "description": "Expert guides on Xbox gamertag creation, naming trends, and gaming branding strategies.",
};
---

<MainLayout
  title="Xbox Gamertag Tips, Guides & Gaming Articles | Expert Advice"
  description="Expert guides on Xbox gamertag creation, naming trends, gaming branding strategies, and profile optimization tips."
  keywords="xbox gamertag tips, gaming guides, xbox naming advice, gamertag ideas, gaming articles"
  {schema}
>
  <Header />

  <div class="min-h-screen bg-[#000000]">

    <!-- ── Hero ── -->
    <section class="bg-[#000000] relative overflow-hidden py-16 md:py-20">
      <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 70% 55% at 50% 0%, rgba(0,208,43,0.10) 0%, transparent 65%);"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-8 lg:px-12 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-sm mb-6">
          <span class="font-[Rajdhani] text-[10px] font-bold tracking-[3px] uppercase text-[#00D02B]">Gaming Guides</span>
        </div>
        <h1 class="font-[Orbitron] text-3xl md:text-4xl font-black text-white mb-4 leading-tight">
          Xbox Naming Tips, <span class="text-[#00D02B]">Guides</span> &amp; Strategies
        </h1>
        <p class="font-[Rajdhani] text-lg md:text-xl text-[#94A3B8] mb-3 max-w-2xl mx-auto">
          Everything you need to create, manage, and master your Xbox gamertag.
        </p>
        <p class="font-[Rajdhani] text-base text-[#4B5563] max-w-xl mx-auto">
          Explore in-depth guides, naming trends, and branding strategies to make your gamer identity stand out.
        </p>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, #1F2937 20%, #00D02B 50%, #1F2937 80%, transparent);"></div>
    </section>

    <!-- ── Search — White section ── -->
    <section class="bg-[#ffffff] py-12 border-t border-[#E2E8F0]">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 md:px-8">

        <div class="text-center mb-8">
          <h2 class="font-[Orbitron] text-xl font-bold text-[#050505]">Tips, Guides &amp; Articles</h2>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 items-center">
          <div class="relative flex-1 w-full">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-[#CBD5E1] h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
            </svg>
            <input
              id="searchInput"
              type="text"
              placeholder="Search for articles..."
              class="w-full h-11 pl-10 pr-4 bg-[#F8FAFC] border border-[#E2E8F0] rounded-lg font-[Rajdhani] text-sm font-semibold text-[#050505] placeholder-[#CBD5E1] focus:outline-none focus:border-[#00D02B] focus:ring-2 focus:ring-[#00D02B]/12 transition-colors"
            />
          </div>
          <button
            id="searchBtn"
            class="w-full sm:w-auto px-6 h-11 bg-[#00D02B] hover:bg-[#00e830] text-black font-[Rajdhani] font-bold text-sm uppercase tracking-widest rounded-lg transition-colors duration-200"
          >
            Search
          </button>
        </div>

        <!-- Ad slot -->
        <div class="bg-[#F8FAFC] border border-dashed border-[#E2E8F0] rounded-lg px-5 py-4 text-center mt-8">
          <p class="font-[Rajdhani] text-[10px] font-bold tracking-[3px] uppercase text-[#CBD5E1] mb-3">Advertisement</p>
          <div class="bg-white border border-[#E2E8F0] rounded h-20 md:h-32 lg:h-40"></div>
        </div>

      </div>
    </section>

    <!-- ── Articles Grid — Dark alt section ── -->
    <section class="bg-[#050505] pt-10 pb-8 border-t border-[#1F2937]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-12">

        <!-- Default title -->
        <h2 id="sectionTitle" class="font-[Orbitron] text-xl font-bold text-white text-center mb-8">
          Latest Articles
        </h2>

        <!-- Search results header -->
        <div id="resultsHeader" class="hidden flex items-center justify-between mb-6">
          <h2 id="resultsTitle" class="font-[Orbitron] text-xl font-bold text-white"></h2>
          <button id="clearBtn" class="font-[Rajdhani] text-sm font-bold text-[#00D02B] hover:underline uppercase tracking-wide">
            Clear Search
          </button>
        </div>

        <!-- No results -->
        <div id="noResults" class="hidden text-center py-16">
          <p id="noResultsMsg" class="font-[Orbitron] text-base text-[#94A3B8] mb-3"></p>
          <p class="font-[Rajdhani] text-sm text-[#4B5563] mb-6">Try searching with different keywords or browse our latest articles below.</p>
          <button
            id="viewAllBtn"
            class="inline-flex items-center justify-center px-6 py-2.5 bg-[#00D02B] hover:bg-[#00e830] text-black font-[Rajdhani] font-bold text-sm uppercase tracking-widest rounded transition-colors duration-200"
          >
            View All Articles
          </button>
        </div>

        <!-- Blog grid -->
        <div
          id="blogGrid"
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
          data-posts={JSON.stringify(blogPosts)}
        >
          {blogPosts.map((post) => (
            <article class="group bg-[#000000] border border-[#1F2937] rounded-xl overflow-hidden transition-all duration-200 hover:border-[#00D02B]/40 hover:-translate-y-0.5">
              <div class="h-0.5 w-full bg-[#1F2937] group-hover:bg-[#00D02B] transition-colors duration-200"></div>
              <div class="w-full h-36 bg-[#050505] border-b border-[#1F2937] flex items-center justify-center">
                <span class="font-[Rajdhani] text-xs text-[#4B5563] uppercase tracking-wider">Gaming Image</span>
              </div>
              <div class="p-4">
                <h3 class="font-[Orbitron] text-xs font-bold text-white mb-2 leading-snug group-hover:text-[#00D02B] transition-colors duration-200 line-clamp-2">{post.title}</h3>
                <p class="font-[Rajdhani] text-sm text-[#94A3B8] mb-4 line-clamp-3 leading-relaxed">{post.excerpt}</p>
                <a
                  href={`/blog/${post.slug}`}
                  class="inline-flex items-center gap-1.5 font-[Rajdhani] text-xs font-bold uppercase tracking-wider text-[#00D02B]"
                >
                  Read More
                  <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ── Pagination ── -->
    <section class="bg-[#050505] pb-10 border-b border-[#1F2937]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-12">
        <div class="flex justify-center items-center gap-2 sm:gap-3">
          <button class="flex items-center gap-1.5 px-4 py-2 bg-transparent border border-[#1F2937] text-[#94A3B8] font-[Rajdhani] text-xs font-bold uppercase tracking-wide rounded hover:border-[#00D02B]/40 hover:text-[#00D02B] transition-all duration-150">
            <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Prev
          </button>
          <div class="flex gap-1.5">
            <button class="w-8 h-8 bg-[#00D02B] text-black font-[Orbitron] text-[10px] font-bold rounded">1</button>
            <button class="w-8 h-8 bg-transparent border border-[#1F2937] text-[#94A3B8] font-[Orbitron] text-[10px] font-bold rounded hover:border-[#00D02B]/40 hover:text-[#00D02B] transition-all">2</button>
            <button class="w-8 h-8 bg-transparent border border-[#1F2937] text-[#94A3B8] font-[Orbitron] text-[10px] font-bold rounded hover:border-[#00D02B]/40 hover:text-[#00D02B] transition-all">3</button>
            <span class="w-8 h-8 flex items-center justify-center text-[#4B5563] font-[Rajdhani] text-sm">...</span>
          </div>
          <button class="flex items-center gap-1.5 px-4 py-2 bg-transparent border border-[#1F2937] text-[#94A3B8] font-[Rajdhani] text-xs font-bold uppercase tracking-wide rounded hover:border-[#00D02B]/40 hover:text-[#00D02B] transition-all duration-150">
            Next
            <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
      </div>
    </section>

    <!-- ── Bottom Ad ── -->
    <section class="bg-[#050505] py-12">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-12">
        <div class="bg-white/[0.02] border border-dashed border-[#1F2937] rounded-lg px-5 py-4 text-center">
          <p class="font-[Rajdhani] text-[10px] font-bold tracking-[3px] uppercase text-[#4B5563] mb-3">Advertisement</p>
          <div class="bg-[#050505] rounded h-24 md:h-32 lg:h-48"></div>
        </div>
      </div>
    </section>

  </div>

  <script>
    type Post = {
      id: string;
      title: string;
      excerpt: string;
      readTime: string;
      slug: string;
    };

    const grid          = document.getElementById("blogGrid")      as HTMLElement;
    const sectionTitle  = document.getElementById("sectionTitle")  as HTMLElement;
    const resultsHeader = document.getElementById("resultsHeader") as HTMLElement;
    const resultsTitle  = document.getElementById("resultsTitle")  as HTMLElement;
    const noResults     = document.getElementById("noResults")     as HTMLElement;
    const noResultsMsg  = document.getElementById("noResultsMsg")  as HTMLElement;
    const searchInput   = document.getElementById("searchInput")   as HTMLInputElement;
    const searchBtn     = document.getElementById("searchBtn")     as HTMLButtonElement;
    const clearBtn      = document.getElementById("clearBtn")      as HTMLButtonElement;
    const viewAllBtn    = document.getElementById("viewAllBtn")    as HTMLButtonElement;

    const posts: Post[] = JSON.parse(grid.dataset.posts ?? "[]");

    function cardHTML(post: Post): string {
      return `
        <article class="group bg-[#000000] border border-[#1F2937] rounded-xl overflow-hidden transition-all duration-200 hover:border-[#00D02B]/40 hover:-translate-y-0.5">
          <div class="h-0.5 w-full bg-[#1F2937] group-hover:bg-[#00D02B] transition-colors duration-200"></div>
          <div class="w-full h-36 bg-[#050505] border-b border-[#1F2937] flex items-center justify-center">
            <span class="font-[Rajdhani] text-xs text-[#4B5563] uppercase tracking-wider">Gaming Image</span>
          </div>
          <div class="p-4">
            <h3 class="font-[Orbitron] text-xs font-bold text-white mb-2 leading-snug line-clamp-2">${post.title}</h3>
            <p class="font-[Rajdhani] text-sm text-[#94A3B8] mb-4 line-clamp-3 leading-relaxed">${post.excerpt}</p>
            <a href="/blog/${post.slug}" class="inline-flex items-center gap-1.5 font-[Rajdhani] text-xs font-bold uppercase tracking-wider text-[#00D02B]" onclick="window.scrollTo({top:0,behavior:'smooth'})">
              Read More
              <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>`;
    }

    function showAll() {
      sectionTitle.textContent = "Latest Articles";
      sectionTitle.classList.remove("hidden");
      resultsHeader.classList.add("hidden");
      noResults.classList.add("hidden");
      grid.classList.remove("hidden");
      grid.innerHTML = posts.map(cardHTML).join("");
      searchInput.value = "";
    }

    function handleSearch() {
      const term = searchInput.value.trim().toLowerCase();
      if (!term) return;
      sectionTitle.textContent = "Searching...";
      sectionTitle.classList.remove("hidden");
      resultsHeader.classList.add("hidden");
      setTimeout(() => {
        const results = posts.filter(
          (p) => p.title.toLowerCase().includes(term) || p.excerpt.toLowerCase().includes(term)
        );
        sectionTitle.classList.add("hidden");
        resultsHeader.classList.remove("hidden");
        resultsTitle.textContent = `Search Results (${results.length})`;
        if (results.length === 0) {
          noResultsMsg.textContent = `No articles found for "${searchInput.value}"`;
          noResults.classList.remove("hidden");
          grid.classList.add("hidden");
        } else {
          noResults.classList.add("hidden");
          grid.classList.remove("hidden");
          grid.innerHTML = results.map(cardHTML).join("");
        }
      }, 500);
    }

    searchBtn.addEventListener("click", handleSearch);
    searchInput.addEventListener("keydown", (e) => { if (e.key === "Enter") handleSearch(); });
    clearBtn.addEventListener("click", showAll);
    viewAllBtn.addEventListener("click", showAll);
  </script>
</MainLayout>