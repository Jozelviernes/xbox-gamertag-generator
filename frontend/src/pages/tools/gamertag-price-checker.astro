---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/layout/Header.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Xbox Gamertag Price Checker",
  "url": "https://xboxgamertaggenerator.com/tools/gamertag-price-checker",
  "description": "Check how much an Xbox gamertag costs to change. Find out the current price for gamertag changes on Xbox.",
  "applicationCategory": "GameApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<MainLayout
  title="Xbox Gamertag Price Checker | How Much Does a Name Change Cost?"
  description="Find out exactly how much it costs to change your Xbox gamertag. Check current Xbox name change pricing, free change eligibility, and what affects the cost."
  keywords="xbox gamertag price, xbox name change cost, how much to change xbox gamertag, xbox gamertag change fee, xbox name change price"
  {schema}
>
  <Header />

  <div class="min-h-screen bg-[#000000] text-white">

    <!-- ── Hero ── -->
    <section class="bg-[#000000] relative overflow-hidden py-14 md:py-20">
      <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 70% 55% at 50% 0%, rgba(0,208,43,0.10) 0%, transparent 65%);"></div>
      <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-8 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-sm mb-6">
          <span class="font-[Rajdhani] text-[10px] font-bold tracking-[3px] uppercase text-[#00D02B]">Free Tool</span>
        </div>
        <h1 class="font-[Orbitron] text-3xl md:text-4xl font-black text-white mb-4 leading-tight">
          Xbox Gamertag <span class="text-[#00D02B]">Price Checker</span>
        </h1>
        <p class="font-[Rajdhani] text-base md:text-lg text-[#94A3B8] max-w-xl mx-auto leading-relaxed">
          Ever wondered what your gamertag might be worth? Get a quick data-based
          estimate based on length, rarity, and demand.
        </p>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, #1F2937 20%, #00D02B 50%, #1F2937 80%, transparent);"></div>
    </section>

    <!-- ── Tool ── -->
    <section class="py-10 bg-[#050505]">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 space-y-5">

        <!-- Input Card -->
        <div class="bg-[#000000] border border-[#1F2937] rounded-xl p-6">
          <label class="font-[Rajdhani] text-xs font-bold tracking-[2px] uppercase text-[#94A3B8] block mb-3">
            Enter your Xbox Gamertag
          </label>
          <div class="flex gap-3">
            <input
              id="gamertagInput"
              type="text"
              maxlength="12"
              placeholder="e.g. ShadowWolf"
              class="flex-1 px-4 py-3 bg-[#050505] border border-[#1F2937] rounded-lg text-white placeholder-[#4B5563] font-[Rajdhani] text-sm font-semibold focus:outline-none focus:border-[#00D02B] focus:ring-2 focus:ring-[#00D02B]/15 transition-colors"
            />
            <button
              id="checkBtn"
              class="px-6 py-3 bg-[#00D02B] hover:bg-[#00e830] text-black font-[Rajdhani] font-bold text-sm uppercase tracking-widest rounded-lg transition-colors duration-200 whitespace-nowrap disabled:opacity-40 disabled:cursor-not-allowed"
            >
              Check Price
            </button>
          </div>
          <p class="font-[Rajdhani] text-xs text-[#4B5563] mt-2">
            Max 12 characters · Letters, numbers and spaces only
          </p>
          <p class="font-[Rajdhani] text-xs text-[#4B5563] mt-1 leading-relaxed">
            Tip: Short, clean tags often score higher. Premium-looking names often use strong letters
            like Z, X, V, K, or Y — but avoid too many numbers or old-style patterns like xX or underscores.
          </p>
        </div>

        <!-- Loading -->
        <div id="loadingState" class="hidden text-center py-12">
         <div
  class="inline-block w-8 h-8 rounded-full animate-spin mb-4"
  style="border: 2px solid #1F2937; border-top-color: #00D02B;"
></div>
          <p class="font-[Rajdhani] text-sm text-[#94A3B8] tracking-wide">Analyzing your gamertag...</p>
        </div>

        <!-- Error -->
        <div id="errorState" class="hidden bg-red-500/[0.06] border border-red-500/30 rounded-xl p-6 text-center">
          <p id="errorMsg" class="font-[Rajdhani] text-sm font-bold text-red-400"></p>
        </div>

        <!-- Results -->
        <div id="results" class="hidden space-y-4">

          <!-- Tier + Price Card -->
          <div class="bg-[#000000] border border-[#1F2937] rounded-xl p-8 text-center">
            <p class="font-[Rajdhani] text-xs font-bold tracking-[2px] uppercase text-[#4B5563] mb-2">Estimated value for</p>
            <h2 id="resultTag" class="font-[Orbitron] text-3xl font-black text-white mb-5"></h2>

            <div id="tierBadge"
              class="inline-flex items-center gap-2 px-5 py-2 rounded-full text-sm font-semibold mb-6">
            </div>

            <div class="font-[Orbitron] text-5xl font-black text-[#00D02B] mb-2" id="priceRange"></div>
            <p class="font-[Rajdhani] text-xs text-[#4B5563] uppercase tracking-wider">Estimated market value</p>
          </div>

          <!-- Score Bar Card -->
          <div class="bg-[#000000] border border-[#1F2937] rounded-xl p-6">
            <div class="flex items-center justify-between mb-3">
              <span class="font-[Rajdhani] text-xs font-bold tracking-[2px] uppercase text-[#94A3B8]">Rarity Score</span>
              <span id="scoreValue" class="font-[Orbitron] text-sm font-bold text-[#00D02B]"></span>
            </div>
            <div class="w-full bg-[#1F2937] rounded-full h-3 overflow-hidden">
              <div
                id="scoreBar"
                class="h-3 rounded-full transition-all duration-700 ease-out"
                style="width: 0%"
              ></div>
            </div>
            <div class="flex justify-between font-[Rajdhani] text-xs text-[#4B5563] mt-1.5">
              <span>0</span>
              <span>25</span>
              <span>50</span>
              <span>75</span>
              <span>100</span>
            </div>
          </div>

          <!-- Breakdown Card -->
          <div class="bg-[#000000] border border-[#1F2937] rounded-xl p-6">
            <h3 class="font-[Orbitron] text-sm font-bold text-white mb-5">
              Score Breakdown
            </h3>
            <div id="breakdownList" class="space-y-0"></div>
          </div>

          <!-- Try Another -->
          <div class="text-center">
            <button
              id="resetBtn"
              class="px-6 py-3 bg-transparent border border-[#1F2937] hover:border-[#00D02B]/40 text-[#94A3B8] hover:text-[#00D02B] font-[Rajdhani] font-bold text-sm uppercase tracking-widest rounded-lg transition-all duration-150"
            >
              Check Another Gamertag
            </button>
          </div>

          <!-- Disclaimer -->
          <p class="font-[Rajdhani] text-xs text-[#4B5563] text-center px-4 pb-4 leading-relaxed">
            This is an estimate for entertainment purposes only. Actual gamertag
            value depends on buyer demand and is not guaranteed. Selling Xbox
            gamertags may violate Microsoft's Terms of Service.
          </p>

        </div>

      </div>
    </section>

    <!-- ── Ad slot ── -->
    <section class="pb-16 bg-[#050505]">
      <div class="max-w-2xl mx-auto px-4 sm:px-6">
        <div class="bg-white/[0.02] border border-dashed border-[#1F2937] rounded-lg px-5 py-4 text-center">
          <p class="font-[Rajdhani] text-[10px] font-bold tracking-[3px] uppercase text-[#4B5563] mb-3">Advertisement</p>
          <div class="bg-[#050505] rounded h-24 md:h-32"></div>
        </div>
      </div>
    </section>

  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL ?? "http://localhost:8000";

    // ── Elements ───────────────────────────────────────────────────
    const input        = document.getElementById("gamertagInput")  as HTMLInputElement;
    const checkBtn     = document.getElementById("checkBtn")       as HTMLButtonElement;
    const resetBtn     = document.getElementById("resetBtn")       as HTMLButtonElement;
    const loadingState = document.getElementById("loadingState")   as HTMLElement;
    const errorState   = document.getElementById("errorState")     as HTMLElement;
    const errorMsg     = document.getElementById("errorMsg")       as HTMLElement;
    const results      = document.getElementById("results")        as HTMLElement;
    const resultTag    = document.getElementById("resultTag")      as HTMLElement;
    const tierBadge    = document.getElementById("tierBadge")      as HTMLElement;
    const priceRange   = document.getElementById("priceRange")     as HTMLElement;
    const scoreValue   = document.getElementById("scoreValue")     as HTMLElement;
    const scoreBar     = document.getElementById("scoreBar")       as HTMLElement;
    const breakdownList = document.getElementById("breakdownList") as HTMLElement;

    // ── Tier styles ────────────────────────────────────────────────
    type Tier = "Legendary" | "Rare" | "Uncommon" | "Common" | "Low Value";

    const tierStyles: Record<Tier, { badge: string; bar: string }> = {
      "Legendary" : {
        badge : "bg-yellow-500/20 text-yellow-400 border border-yellow-500/40",
        bar   : "bg-gradient-to-r from-yellow-500 to-yellow-300",
      },
      "Rare"      : {
        badge : "bg-purple-500/20 text-purple-400 border border-purple-500/40",
        bar   : "bg-gradient-to-r from-purple-500 to-purple-400",
      },
      "Uncommon"  : {
        badge : "bg-blue-500/20 text-blue-400 border border-blue-500/40",
        bar   : "bg-gradient-to-r from-blue-500 to-blue-400",
      },
      "Common"    : {
        badge : "bg-[#00D02B]/10 text-[#00D02B] border border-[#00D02B]/30",
        bar   : "bg-[#00D02B]",
      },
      "Low Value" : {
        badge : "bg-white/[0.04] text-[#94A3B8] border border-[#1F2937]",
        bar   : "bg-[#4B5563]",
      },
    };

    // ── Helpers ────────────────────────────────────────────────────
    function showOnly(el: HTMLElement) {
      [loadingState, errorState, results].forEach((e) =>
        e.classList.add("hidden")
      );
      el.classList.remove("hidden");
    }

    function resetTool() {
      [loadingState, errorState, results].forEach((e) =>
        e.classList.add("hidden")
      );
      input.value = "";
      scoreBar.style.width = "0%";
      input.focus();
    }

    // ── Render ─────────────────────────────────────────────────────
    function renderResults(data: {
      gamertag  : string;
      score     : number;
      tier      : Tier;
      emoji     : string;
      priceRange: string;
      breakdown : { label: string; points: number; note: string }[];
    }) {
      const style = tierStyles[data.tier] ?? tierStyles["Low Value"];

      resultTag.textContent  = data.gamertag;
      priceRange.textContent = data.priceRange;
      scoreValue.textContent = `${data.score} / 100`;

      // Score bar color + animate
      scoreBar.className = `h-3 rounded-full transition-all duration-700 ease-out ${style.bar}`;
      setTimeout(() => {
        scoreBar.style.width = `${data.score}%`;
      }, 100);

      // Tier badge
      tierBadge.className = `inline-flex items-center gap-2 px-5 py-2 rounded-full text-sm font-semibold mb-6 ${style.badge}`;
      tierBadge.innerHTML = `${data.emoji} ${data.tier}`;

      // Breakdown rows
      breakdownList.innerHTML = data.breakdown
        .map(
          (item) => `
          <div class="flex items-start justify-between py-3 border-b border-[#1F2937] last:border-0 gap-4">
            <div class="flex-1">
              <p class="font-[Rajdhani] text-sm font-bold text-white">${item.label}</p>
              <p class="font-[Rajdhani] text-xs text-[#4B5563] mt-0.5">${item.note}</p>
            </div>
            <span class="font-[Orbitron] text-xs font-bold shrink-0 ${
              item.points > 0
                ? "text-[#00D02B]"
                : item.points < 0
                ? "text-red-400"
                : "text-[#4B5563]"
            }">
              ${item.points > 0 ? "+" : ""}${item.points} pts
            </span>
          </div>`
        )
        .join("");
    }

    // ── Main fetch ─────────────────────────────────────────────────
    async function checkPrice() {
      const tag = input.value.trim();

      if (!tag) {
        errorMsg.textContent = "Please enter a gamertag first.";
        showOnly(errorState);
        return;
      }

      showOnly(loadingState);
      checkBtn.disabled = true;

      try {
        const res = await fetch(`${API_URL}/api/check-price`, {
          method : "POST",
          headers: {
            "Content-Type": "application/json",
            "Accept"       : "application/json",
          },
          body: JSON.stringify({ gamertag: tag }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(
            err?.message ?? `Server error (${res.status}). Please try again.`
          );
        }

        const data = await res.json();
        renderResults(data);
        showOnly(results);
      } catch (err: any) {
        errorMsg.textContent =
          err.message ?? "Something went wrong. Please try again.";
        showOnly(errorState);
      } finally {
        checkBtn.disabled = false;
      }
    }

    // ── Events ─────────────────────────────────────────────────────
    checkBtn.addEventListener("click", checkPrice);
    resetBtn.addEventListener("click", resetTool);
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") checkPrice();
    });
  </script>
</MainLayout>