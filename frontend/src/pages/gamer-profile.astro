---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/layout/Header.astro';
---

<MainLayout
  title="Gamer Profile Checker — Xbox Stats Lookup"
  description="Look up public Xbox gamer profiles, gamerscore, bio, and other profile details."
>
  <Header />

  <section class="section-dark min-h-screen py-20 px-4">
    <div class="max-w-2xl mx-auto">

      <!-- Header -->
      <div class="text-center mb-10 animate-fade-in-up">
        <span class="label-green mb-3 block">Xbox Tools</span>
        <h1 class="heading-hero text-3xl md:text-4xl text-foreground mb-4">
          Gamer <span class="text-brand">Profile</span>
        </h1>
        <p class="text-foreground-muted text-sm">
          Look up any public Xbox profile — gamerscore, bio, followers, and more.
        </p>
      </div>

      <!-- Search Card -->
      <div class="game-card p-6 md:p-8 animate-fade-in-up-delay">
        <div class="flex gap-3">
          <input
            id="profile-input"
            class="input-dark flex-1"
            type="text"
            placeholder="Enter gamertag…"
            maxlength="15"
            autocomplete="off"
            spellcheck="false"
          />
          <button id="search-btn" class="btn-primary whitespace-nowrap">
            Look Up
          </button>
        </div>
      </div>

      <!-- Loading -->
      <div id="loading" class="hidden mt-8 flex items-center justify-center gap-3 text-foreground-muted text-sm">
        <svg class="animate-spin w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
        </svg>
        Fetching profile from Xbox Live…
      </div>

      <!-- Error -->
      <div id="error" class="hidden mt-8 game-card p-6 border-red-700/40 text-center">
        <p class="text-red-400 font-semibold" id="error-msg">Something went wrong.</p>
      </div>

      <!-- Profile Card -->
      <div id="profile-card" class="hidden mt-8 animate-fade-in-up">
        <div class="game-card p-6 md:p-8">
          <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">

            <!-- Avatar -->
            <div class="relative shrink-0">
              <img
                id="profile-avatar"
                src=""
                alt="Avatar"
                class="w-24 h-24 rounded-lg border border-green object-cover shadow-green bg-surface"
                onerror="this.onerror=null; this.src='https://avatar-ssl.xboxlive.com/avatar/Major%20Nelson/avatar-body.png'"
              />
              <div id="tier-badge" class="absolute -bottom-2 -right-2"></div>
            </div>

            <!-- Identity -->
            <div class="text-center sm:text-left flex-1">
              <h2 id="profile-gamertag" class="heading-hero text-2xl md:text-3xl text-foreground"></h2>
              <p id="profile-bio" class="text-foreground-muted text-sm mt-2 max-w-sm"></p>
              <div class="flex flex-wrap justify-center sm:justify-start gap-3 mt-3">
                <span id="profile-location" class="hidden label-mono flex items-center gap-1"></span>
                <span id="profile-realname" class="hidden label-mono flex items-center gap-1 text-foreground-subtle"></span>
              </div>
            </div>

          </div>

          <div class="border-t border-default my-6"></div>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="text-center p-3 rounded-lg bg-background-alt border border-default">
              <p class="text-brand font-display font-bold text-xl" id="stat-gamerscore">—</p>
              <p class="label-mono mt-1">Gamerscore</p>
            </div>
            <div class="text-center p-3 rounded-lg bg-background-alt border border-default">
              <p class="text-foreground font-bold text-xl" id="stat-tenure">—</p>
              <p class="label-mono mt-1">Tenure (yrs)</p>
            </div>
            <div class="text-center p-3 rounded-lg bg-background-alt border border-default">
              <p class="text-foreground font-bold text-xl" id="stat-followers">—</p>
              <p class="label-mono mt-1">Followers</p>
            </div>
            <div class="text-center p-3 rounded-lg bg-background-alt border border-default">
              <p class="text-foreground font-bold text-xl" id="stat-following">—</p>
              <p class="label-mono mt-1">Following</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  <div class="mt-10 max-w-2xl mx-auto rounded-lg px-6 py-10 text-center border border-dashed border-default bg-background-surface">
  <p class="label-mono text-foreground-subtle mb-3">Advertisement</p>
  <div class="h-20 md:h-28 rounded bg-background-alt"></div>
</div>
  </section>
</MainLayout>

<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';

  const input       = document.getElementById('profile-input') as HTMLInputElement;
  const btn         = document.getElementById('search-btn') as HTMLButtonElement;
  const loadingEl   = document.getElementById('loading')!;
  const errorEl     = document.getElementById('error')!;
  const errorMsg    = document.getElementById('error-msg')!;
  const profileCard = document.getElementById('profile-card')!;

  function fmt(n: number) {
    return n >= 1000 ? (n / 1000).toFixed(1) + 'k' : String(n);
  }

  function escHtml(str: string) {
    return (str ?? '').replace(/[&<>"']/g, c =>
      ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!));
  }

  function showError(msg: string) {
    profileCard.classList.add('hidden');
    errorEl.classList.remove('hidden');
    errorMsg.textContent = msg;
  }

  function resetProfileUI() {
    const avatar = document.getElementById('profile-avatar') as HTMLImageElement;
    const tierBadge = document.getElementById('tier-badge')!;
    const locEl = document.getElementById('profile-location')!;
    const nameEl = document.getElementById('profile-realname')!;
    const bioEl = document.getElementById('profile-bio')!;

    avatar.src = '';
    avatar.alt = 'Avatar';
    tierBadge.innerHTML = '';
    locEl.textContent = '';
    nameEl.textContent = '';
    bioEl.textContent = '';

    locEl.classList.add('hidden');
    nameEl.classList.add('hidden');

    (document.getElementById('profile-gamertag')!).textContent = '';
    (document.getElementById('stat-gamerscore')!).textContent = '—';
    (document.getElementById('stat-tenure')!).textContent = '—';
    (document.getElementById('stat-followers')!).textContent = '—';
    (document.getElementById('stat-following')!).textContent = '—';
  }

  function populateProfile(p: Record<string, any>) {
    resetProfileUI();

    const avatar = document.getElementById('profile-avatar') as HTMLImageElement;
    avatar.src = p.avatar || '';
    avatar.alt = p.gamertag ?? 'Avatar';

    (document.getElementById('profile-gamertag')!).textContent = p.gamertag ?? '—';

    const bioEl = document.getElementById('profile-bio')!;
    bioEl.textContent = p.bio || 'No bio set.';

    const tierBadge = document.getElementById('tier-badge')!;
    if (p.account_tier === 'Gold') {
      tierBadge.innerHTML = `<span class="badge-brand text-xs px-2 py-0.5 rounded">GOLD</span>`;
    } else if (p.account_tier) {
      tierBadge.innerHTML = `<span class="badge-rarity-common text-xs px-2 py-0.5 rounded">${escHtml(p.account_tier)}</span>`;
    }

    const locEl = document.getElementById('profile-location')!;
    if (p.location) {
      locEl.textContent = '📍 ' + p.location;
      locEl.classList.remove('hidden');
    }

    const nameEl = document.getElementById('profile-realname')!;
    if (p.real_name) {
      nameEl.textContent = p.real_name;
      nameEl.classList.remove('hidden');
    }

    (document.getElementById('stat-gamerscore')!).textContent = fmt(p.gamerscore ?? 0);
    (document.getElementById('stat-tenure')!).textContent     = p.tenure ?? '—';
    (document.getElementById('stat-followers')!).textContent  = fmt(p.followers ?? 0);
    (document.getElementById('stat-following')!).textContent  = fmt(p.following ?? 0);
  }

  async function lookupProfile() {
    const tag = input.value.trim();
    if (!tag) return;

    profileCard.classList.add('hidden');
    errorEl.classList.add('hidden');
    loadingEl.classList.remove('hidden');
    btn.disabled = true;

    try {
      const res = await fetch(
        `${API_BASE}/api/xbox/profile?gamertag=${encodeURIComponent(tag)}`,
        { headers: { 'Accept': 'application/json' } }
      );

      const raw = await res.text();
      let data: any = {};

      try {
        data = raw ? JSON.parse(raw) : {};
      } catch {
        throw new Error('Invalid server response.');
      }

      if (data.error) {
        showError(data.message ?? 'Something went wrong.');
        return;
      }

      if (data.found === false) {
        showError(data.message ?? 'Gamertag not found.');
        return;
      }

      if (!data.profile) {
        showError('Profile data is missing.');
        return;
      }

      populateProfile(data.profile);
      profileCard.classList.remove('hidden');

    } catch (err: any) {
      showError(err?.message ?? 'Network error. Please check your connection.');
    } finally {
      loadingEl.classList.add('hidden');
      btn.disabled = false;
    }
  }

  btn.addEventListener('click', lookupProfile);
  input.addEventListener('keydown', e => { if (e.key === 'Enter') lookupProfile(); });
</script>