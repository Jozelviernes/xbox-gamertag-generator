---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";

const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");
const glossaryApiUrl =
  `${import.meta.env.PUBLIC_API_BASE_URL || "https://api.xboxgamertaggenerator.com"}/api/glossary`;

const pageUrl = "https://xboxgamertaggenerator.com/glossary";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "DefinedTermSet",
    "name": "Xbox & Gaming Glossary",
    "url": pageUrl,
    "description": "Browse clear definitions of Xbox terms, gaming slang, naming rules, and gamer culture.",
    "inLanguage": "en-US",
    "publisher": {
      "@type": "Organization",
      "name": "Xbox Gamertag Generator",
      "url": "https://xboxgamertaggenerator.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://xboxgamertaggenerator.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Glossary",
        "item": pageUrl
      }
    ]
  }
];
---

<MainLayout
  title="Xbox Glossary – Gaming Terms, Xbox Slang & Naming Rules"
  description="Explore Xbox terms, gaming slang, naming rules, and gamer culture with clear glossary definitions designed for Xbox players and gamertag creators."
  canonical={pageUrl}
  {schema}
>
  <Header />

  <div class="min-h-screen bg-background text-foreground font-ui">
   <!-- Hero -->
<section class="section-dark-alt py-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 2xl:px-16">
    <section class="bg-card py-16 rounded-lg">
      <div class="px-6 text-center">

        <h1 class="font-ui text-3xl md:text-4xl font-bold mb-4 text-foreground">
          Xbox &amp; Gaming <span class="text-brand">Glossary</span>
        </h1>

        <p class="font-ui text-lg md:text-xl text-foreground-muted mb-4 max-w-3xl mx-auto">
          Understand the lingo. Game smarter.
        </p>

        <p class="font-ui text-base text-foreground-muted max-w-2xl mx-auto">
          Explore clear definitions of Xbox terms, naming rules, and gamer culture. Build your knowledge and level up your naming game.
        </p>

      </div>
    </section>
  </div>
</section>
   <section class="section-white py-10 border-b border-[#E5E7EB]">
  <div class="max-w-5xl mx-auto px-4 sm:px-8 lg:px-12">
    <div class="mb-10">
      <div class="relative max-w-2xl mx-auto">
        <input
          id="searchInput"
          type="text"
          placeholder="Search terms..."
          class="w-full h-12 px-5 pr-12 bg-white border border-[#E5E7EB] rounded-lg text-[#111827] placeholder-[#9CA3AF] text-sm md:text-base font-semibold focus:border-[#00D02B] focus:outline-none focus:ring-2 focus:ring-[#00D02B]/15 transition-colors"
        />
        <svg class="absolute right-4 top-1/2 -translate-y-1/2 h-4 w-4 text-[#9CA3AF]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <circle cx="11" cy="11" r="7" stroke-width="2"></circle>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 20l-3.5-3.5" />
        </svg>
      </div>
    </div>

    <div>
      <p class="text-[10px] font-bold tracking-[3px] uppercase text-[#94A3B8] mb-4 text-center font-ui">
        Browse by Letter
      </p>
      <div id="lettersWrap" class="flex flex-wrap justify-center gap-2">
        {letters.map((letter) => (
          <button
            type="button"
            class="letter-btn w-8 h-8 md:w-9 md:h-9 border border-[#E5E7EB] rounded bg-white text-[#6B7280] flex items-center justify-center text-[10px] font-bold transition-all duration-150 hover:border-[#00D02B]/50 hover:text-[#00D02B] hover:bg-[#00D02B]/[0.06]"
            data-letter={letter}
          >
            {letter}
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

    <section class="section-white py-14">
  <div class="max-w-5xl mx-auto px-4 sm:px-8 lg:px-12">
    <div id="glossaryData" data-api-url={glossaryApiUrl}></div>

    <div id="loadingState" class="text-center py-16">
      <p class="font-ui text-base text-[#6B7280]">Loading glossary terms...</p>
    </div>

    <div id="noResults" class="hidden text-center py-16">
      <p class="font-ui text-base text-[#6B7280]">No terms found.</p>
      <p class="font-ui text-sm text-[#9CA3AF] mt-2">Try a different search or letter.</p>
    </div>

    <div id="termsGrid" class="grid grid-cols-1 lg:grid-cols-2 gap-4"></div>

    <div id="paginationWrap" class="hidden mt-12 flex flex-wrap items-center justify-center gap-2 px-4 sm:px-0">
  <button
    id="prevBtn"
    type="button"
    class="flex shrink-0 items-center gap-1 px-3 sm:px-4 py-2 bg-white border border-[#E5E7EB] text-[#6B7280] text-xs sm:text-sm font-bold uppercase tracking-wide rounded hover:border-[#00D02B]/40 hover:text-[#00D02B] disabled:opacity-30 disabled:cursor-not-allowed transition-all duration-150"
  >
    <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
    <span class="hidden sm:inline">Prev</span>
  </button>

  <div
    id="pageNumbers"
    class="flex items-center gap-1.5 overflow-x-auto max-w-full whitespace-nowrap px-1 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
  ></div>

  <button
    id="nextBtn"
    type="button"
    class="flex shrink-0 items-center gap-1 px-3 sm:px-4 py-2 bg-white border border-[#E5E7EB] text-[#6B7280] text-xs sm:text-sm font-bold uppercase tracking-wide rounded hover:border-[#00D02B]/40 hover:text-[#00D02B] disabled:opacity-30 disabled:cursor-not-allowed transition-all duration-150"
  >
    <span class="hidden sm:inline">Next</span>
    <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>
</div>
  </div>
</section>
  </div>

  <script>
    interface Term {
      term: string;
      definition: string;
      letter: string;
      category?: string;
    }

    const dataEl = document.getElementById("glossaryData");
    const searchInput = document.getElementById("searchInput");
    const letterButtons = Array.from(document.querySelectorAll(".letter-btn"));
    const termsGrid = document.getElementById("termsGrid");
    const noResults = document.getElementById("noResults");
    const loadingState = document.getElementById("loadingState");
    const paginationWrap = document.getElementById("paginationWrap");
    const prevBtn = document.getElementById("prevBtn");
    const nextBtn = document.getElementById("nextBtn");
    const pageNumbers = document.getElementById("pageNumbers");

    if (
      !(dataEl instanceof HTMLElement) ||
      !(searchInput instanceof HTMLInputElement) ||
      !(termsGrid instanceof HTMLElement) ||
      !(noResults instanceof HTMLElement) ||
      !(loadingState instanceof HTMLElement) ||
      !(paginationWrap instanceof HTMLElement) ||
      !(prevBtn instanceof HTMLButtonElement) ||
      !(nextBtn instanceof HTMLButtonElement) ||
      !(pageNumbers instanceof HTMLElement)
    ) {
      console.error("Glossary elements not found.");
    } else {
      const safeDataEl = dataEl;
      const safeSearchInput = searchInput;
      const safeTermsGrid = termsGrid;
      const safeNoResults = noResults;
      const safeLoadingState = loadingState;
      const safePaginationWrap = paginationWrap;
      const safePrevBtn = prevBtn;
      const safeNextBtn = nextBtn;
      const safePageNumbers = pageNumbers;
      const safeLetterButtons = letterButtons.filter((btn): btn is HTMLButtonElement => btn instanceof HTMLButtonElement);

      const itemsPerPage = 8;
      const apiUrl = safeDataEl.dataset.apiUrl ?? "";

      let searchTerm = "";
      let selectedLetter = "";
      let currentPage = 1;

      let glossaryTerms: Term[] = [];

      function filterTerms(): Term[] {
        return glossaryTerms
          .filter((term) => {
            const matchesSearch =
              term.term.toLowerCase().includes(searchTerm.toLowerCase()) ||
              term.definition.toLowerCase().includes(searchTerm.toLowerCase());
            const matchesLetter = !selectedLetter || term.letter === selectedLetter;
            return matchesSearch && matchesLetter;
          })
          .sort((a, b) => a.term.localeCompare(b.term));
      }

    function renderCards(terms: Term[]) {
  safeTermsGrid.innerHTML = terms.map((term) => `
    <div class="bg-white border border-[#E5E7EB] rounded-xl p-5 transition-all duration-150 hover:border-[#00D02B]/35 hover:shadow-[0_10px_24px_-12px_rgba(0,208,43,0.18)]">
      <h3 class="font-ui text-[17px] md:text-lg font-bold text-[#00B324] mb-2">${term.term}</h3>
      <p class="font-ui text-sm md:text-[15px] text-[#4B5563] leading-relaxed">${term.definition}</p>
    </div>
  `).join("");
}

     function renderPagination(totalPages: number) {
  safePageNumbers.innerHTML = "";

  const pages: (number | string)[] = [];

  if (totalPages <= 7) {
    for (let i = 1; i <= totalPages; i++) {
      pages.push(i);
    }
  } else {
    pages.push(1);

    if (currentPage > 3) {
      pages.push("...");
    }

    const start = Math.max(2, currentPage - 1);
    const end = Math.min(totalPages - 1, currentPage + 1);

    for (let i = start; i <= end; i++) {
      pages.push(i);
    }

    if (currentPage < totalPages - 2) {
      pages.push("...");
    }

    pages.push(totalPages);
  }

  pages.forEach((page) => {
    if (page === "...") {
      const ellipsis = document.createElement("span");
      ellipsis.className = "px-2 text-[#9CA3AF] text-xs sm:text-sm font-bold";
      ellipsis.textContent = "...";
      safePageNumbers.appendChild(ellipsis);
      return;
    }

    const button = document.createElement("button");
    button.type = "button";
    button.textContent = String(page);

    button.className =
      currentPage === page
        ? "w-8 h-8 sm:w-9 sm:h-9 bg-[#00D02B] text-black font-ui text-[10px] sm:text-xs font-bold rounded shrink-0"
        : "w-8 h-8 sm:w-9 sm:h-9 bg-white border border-[#E5E7EB] text-[#6B7280] font-ui text-[10px] sm:text-xs font-bold rounded shrink-0 hover:border-[#00D02B]/40 hover:text-[#00D02B] transition-all duration-150";

    button.addEventListener("click", () => {
      currentPage = Number(page);
      render();
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    safePageNumbers.appendChild(button);
  });

  safePrevBtn.disabled = currentPage === 1;
  safeNextBtn.disabled = currentPage === totalPages || totalPages === 0;
}

     function updateLetterButtons() {
  safeLetterButtons.forEach((btn) => {
    const btnLetter = btn.dataset.letter ?? "";
    if (btnLetter === selectedLetter) {
      btn.className = "letter-btn w-8 h-8 md:w-9 md:h-9 border border-[#00D02B] rounded bg-[#00D02B] text-black flex items-center justify-center text-[10px] font-bold transition-all duration-150";
    } else {
      btn.className = "letter-btn w-8 h-8 md:w-9 md:h-9 border border-[#E5E7EB] rounded bg-white text-[#6B7280] flex items-center justify-center text-[10px] font-bold transition-all duration-150 hover:border-[#00D02B]/50 hover:text-[#00D02B] hover:bg-[#00D02B]/[0.06]";
    }
  });
}

      function render() {
        safeLoadingState.classList.add("hidden");

        const sortedTerms = filterTerms();
        const totalPages = Math.ceil(sortedTerms.length / itemsPerPage);
        const safePage = Math.min(currentPage, totalPages || 1);
        currentPage = safePage;

        const startIndex = (currentPage - 1) * itemsPerPage;
        const currentTerms = sortedTerms.slice(startIndex, startIndex + itemsPerPage);

        updateLetterButtons();

        if (currentTerms.length === 0) {
          safeTermsGrid.innerHTML = "";
          safeNoResults.classList.remove("hidden");
          safePaginationWrap.classList.add("hidden");
          return;
        }

        safeNoResults.classList.add("hidden");
        renderCards(currentTerms);

        if (totalPages > 1) {
          safePaginationWrap.classList.remove("hidden");
          renderPagination(totalPages);
        } else {
          safePaginationWrap.classList.add("hidden");
        }
      }

      async function loadGlossaryTerms() {
        try {
          const response = await fetch(apiUrl, {
            headers: { "Accept": "application/json" }
          });

          if (!response.ok) {
            throw new Error(`Failed to fetch glossary terms: ${response.status}`);
          }

          glossaryTerms = await response.json() as Term[];
          render();
        } catch (error) {
          console.error("Failed to load glossary terms:", error);
          safeLoadingState.classList.add("hidden");
          safeTermsGrid.innerHTML = "";
          safeNoResults.classList.remove("hidden");
          safePaginationWrap.classList.add("hidden");
        }
      }

      safeSearchInput.addEventListener("input", () => {
        searchTerm = safeSearchInput.value;
        selectedLetter = "";
        currentPage = 1;
        render();
      });

      safeLetterButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const letter = btn.dataset.letter ?? "";
          selectedLetter = selectedLetter === letter ? "" : letter;
          currentPage = 1;
          render();
        });
      });

      safePrevBtn.addEventListener("click", () => {
        if (currentPage > 1) {
          currentPage -= 1;
          render();
          window.scrollTo({ top: 0, behavior: "smooth" });
        }
      });

      safeNextBtn.addEventListener("click", () => {
      const totalPages = Math.max(1, Math.ceil(filterTerms().length / itemsPerPage));
        if (currentPage < totalPages) {
          currentPage += 1;
          render();
          window.scrollTo({ top: 0, behavior: "smooth" });
        }
      });

      loadGlossaryTerms();
    }
  </script>
</MainLayout>