---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import image from "../assets/image.png";
---

<MainLayout
  title="About Xbox Gamertag Generator - Our Mission & Story"
  description="Learn about Xbox Gamertag Generator - helping gamers create perfect gaming identities. Discover our mission, tools, and commitment to the gaming community."
>
  <Header />

  <div class="min-h-screen bg-light-grey text-gray-900">
    <!-- Hero Section -->
    <section class="bg-light-grey py-16 md:py-24">
      <div class="mx-auto max-w-6xl px-8 sm:px-12 lg:px-16 text-center md:text-left">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-6xl lg:text-7xl mb-6 text-gray-900 font-bold">
            About <span class="text-xbox-green">Xbox GamerTag Generator</span>
          </h1>
          <h2 class="text-2xl md:text-3xl text-gray-600 mb-8 font-medium">
            Helping gamers find their perfect name.
          </h2>
          <p class="text-lg md:text-xl text-gray-700 leading-relaxed max-w-3xl">
            We're dedicated to making naming effortless, creative, and fun—so you can focus on gaming.
          </p>
        </div>
      </div>
    </section>

    <!-- Brand Story Section -->
    <section class="py-16 md:py-20 bg-light-grey-subtle">
      <div class="mx-auto max-w-6xl px-8 sm:px-12 lg:px-16">
        <div class="max-w-4xl mx-auto">
          <div class="mb-12">
            <h2 class="text-4xl md:text-5xl mb-8 text-center md:text-left text-gray-900 font-bold">
              Our <span class="text-xbox-green">Story</span>
            </h2>
            <div class="border-l-4 border-xbox-green pl-6 mb-8">
              <p class="text-base md:text-lg text-gray-700 leading-relaxed">
                Born from frustration with taken or cringe Xbox names, XboxGamerTagGenerator.com exists to help gamers create identities they're proud of. We know that your gamertag is your online persona, your first impression, and part of your gamer legacy.
              </p>
            </div>
          </div>

          <div>
            <h2 class="text-4xl md:text-5xl mb-8 text-center md:text-left text-gray-900 font-bold">
              Our <span class="text-xbox-green">Mission</span>
            </h2>
            <div class="border-l-4 border-xbox-green pl-6">
              <p class="text-base md:text-lg text-gray-700 leading-relaxed">
                Our mission is to simplify the naming process, offer creative inspiration, and make sure every gamer has a name worth shouting across the lobby.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What We Offer Section -->
    <section class="py-16 md:py-20 bg-light-grey">
      <div class="mx-auto max-w-6xl px-8 sm:px-12 lg:px-16">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl md:text-5xl mb-12 text-center text-gray-900 font-bold">
            What You'll Find <span class="text-xbox-green">Here</span>
          </h2>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-8 h-8 bg-xbox-green rounded-full flex items-center justify-center">
                <svg class="text-white h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl md:text-2xl font-semibold mb-2 text-gray-900">
                  Advanced Gamertag Generator
                </h3>
                <p class="text-base md:text-lg text-gray-600">
                  Powerful tools to create unique, memorable gamertags
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-8 h-8 bg-xbox-green rounded-full flex items-center justify-center">
                <svg class="text-white h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl md:text-2xl font-semibold mb-2 text-gray-900">
                  Naming Guides and Tips
                </h3>
                <p class="text-base md:text-lg text-gray-600">
                  Expert advice on creating the perfect gaming identity
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-8 h-8 bg-xbox-green rounded-full flex items-center justify-center">
                <svg class="text-white h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl md:text-2xl font-semibold mb-2 text-gray-900">
                  Profile Management Tools
                </h3>
                <p class="text-base md:text-lg text-gray-600">
                  Resources to optimize your Xbox gaming profile
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-8 h-8 bg-xbox-green rounded-full flex items-center justify-center">
                <svg class="text-white h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl md:text-2xl font-semibold mb-2 text-gray-900">
                  Gaming Brand Resources
                </h3>
                <p class="text-base md:text-lg text-gray-600">
                  Build and grow your presence in the gaming community
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Team Section -->
    <section class="py-16 md:py-20 bg-light-grey-subtle">
      <div class="mx-auto max-w-6xl px-8 sm:px-12 lg:px-16">
        <div class="max-w-4xl mx-auto text-center md:text-left">
          <h2 class="text-4xl md:text-5xl mb-8 text-gray-900 font-bold">
            Who's <span class="text-xbox-green">Behind This</span>
          </h2>
          <div class="flex flex-col md:flex-row items-center gap-8">
            <div class="flex-shrink-0">
  <img
    src={image.src}
    alt="Team"
    width="128"
    height="128"
    loading="lazy"
    class="w-24 h-24 md:w-32 md:h-32 rounded-full border-4 border-xbox-green object-cover"
  />
</div>
            <div class="flex-1">
              <p class="text-base md:text-lg text-gray-700 leading-relaxed">
                Our Xbox Gamertag Generator is designed to help gamers create unique, fun, and memorable Gamertags with ease. Whether you're looking for something cool, edgy, or completely random, our tool offers endless name ideas to suit every gaming style. We make it simple to find the perfect Gamertag so you can stand out and start playing faster.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 md:py-20 bg-light-grey">
      <div class="mx-auto max-w-6xl px-8 sm:px-12 lg:px-16 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-4xl md:text-5xl mb-8 text-gray-900 font-bold">
            Ready to find your <span class="text-xbox-green">perfect tag?</span>
          </h2>

          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a
              href="/"
              class="bg-xbox-green hover:bg-xbox-green-light text-white font-semibold px-8 py-4 rounded-lg transition-all duration-200 w-full sm:w-auto min-h-[48px] inline-flex items-center justify-center"
            >
              Try the Generator
            </a>

            <a
              href="/tools"
              class="text-xbox-green hover:text-xbox-green-light font-medium underline decoration-2 underline-offset-4 min-h-[48px] inline-flex items-center"
            >
              Explore All Tools
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</MainLayout>