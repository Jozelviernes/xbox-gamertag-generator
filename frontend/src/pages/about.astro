---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import image from "../assets/image.png";

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About Xbox Gamertag Generator",
  "url": "https://xboxgamertaggenerator.com/about",
  "description": "Learn about Xbox Gamertag Generator — helping gamers create perfect gaming identities.",
};
---

<MainLayout
  title="About Xbox Gamertag Generator | Our Mission & Story"
  description="Learn about Xbox Gamertag Generator - helping gamers create perfect gaming identities. Discover our mission, tools, and commitment to the gaming community."
  keywords="xbox gamertag generator, about us, gaming identity, xbox gaming tools"
  {schema}
>
  <Header />

  <div class="min-h-screen bg-[#000000] text-white">

    <!-- ── Hero ── -->
    <section class="bg-[#000000] relative overflow-hidden py-16 md:py-24">
      <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 70% 55% at 50% 0%, rgba(0,208,43,0.10) 0%, transparent 65%);"></div>
      <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-8 lg:px-12 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-sm mb-6">
          <span class="font-[Rajdhani] text-[10px] font-bold tracking-[3px] uppercase text-[#00D02B]">Our Story</span>
        </div>
        <h1 class="font-[Orbitron] text-4xl md:text-5xl lg:text-6xl font-black text-white mb-5 leading-tight">
          About <span class="text-[#00D02B]">Xbox GamerTag Generator</span>
        </h1>
        <p class="font-[Rajdhani] text-xl md:text-2xl text-[#94A3B8] mb-4 font-semibold">
          Helping gamers find their perfect name.
        </p>
        <p class="font-[Rajdhani] text-base text-[#4B5563] leading-relaxed max-w-2xl mx-auto">
          We're dedicated to making naming effortless, creative, and fun—so you can focus on gaming.
        </p>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, #1F2937 20%, #00D02B 50%, #1F2937 80%, transparent);"></div>
    </section>

    <!-- ── Story & Mission — White section ── -->
    <section class="bg-[#ffffff] py-16 md:py-20 border-t border-[#E2E8F0]">
      <div class="max-w-4xl mx-auto px-4 sm:px-8 lg:px-12">

        <!-- Story -->
        <div class="mb-14">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-sm mb-5">
            <span class="font-[Rajdhani] text-[10px] font-bold tracking-[3px] uppercase text-[#00D02B]">Background</span>
          </div>
          <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold text-[#050505] mb-6">
            Our <span class="text-[#00D02B]">Story</span>
          </h2>
          <div class="border-l-4 border-[#00D02B] pl-6">
            <p class="font-[Rajdhani] text-base md:text-lg text-[#64748B] leading-relaxed">
              Born from frustration with taken or cringe Xbox names, XboxGamerTagGenerator.com exists to help gamers create identities they're proud of. We know that your gamertag is your online persona, your first impression, and part of your gamer legacy.
            </p>
          </div>
        </div>

        <!-- Mission -->
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-sm mb-5">
            <span class="font-[Rajdhani] text-[10px] font-bold tracking-[3px] uppercase text-[#00D02B]">Purpose</span>
          </div>
          <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold text-[#050505] mb-6">
            Our <span class="text-[#00D02B]">Mission</span>
          </h2>
          <div class="border-l-4 border-[#00D02B] pl-6">
            <p class="font-[Rajdhani] text-base md:text-lg text-[#64748B] leading-relaxed">
              Our mission is to simplify the naming process, offer creative inspiration, and make sure every gamer has a name worth shouting across the lobby.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── What We Offer — Dark alt section ── -->
    <section class="bg-[#050505] py-16 md:py-20 border-t border-[#1F2937]">
      <div class="max-w-4xl mx-auto px-4 sm:px-8 lg:px-12">
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-sm mb-4">
            <span class="font-[Rajdhani] text-[10px] font-bold tracking-[3px] uppercase text-[#00D02B]">Features</span>
          </div>
          <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold text-white">
            What You'll Find <span class="text-[#00D02B]">Here</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          {[
            { title: "Advanced Gamertag Generator", desc: "Powerful tools to create unique, memorable gamertags" },
            { title: "Naming Guides and Tips", desc: "Expert advice on creating the perfect gaming identity" },
            { title: "Profile Management Tools", desc: "Resources to optimize your Xbox gaming profile" },
            { title: "Gaming Brand Resources", desc: "Build and grow your presence in the gaming community" },
          ].map((item) => (
            <div class="flex items-start gap-4 bg-[#000000] border border-[#1F2937] rounded-lg p-5 transition-all duration-150 hover:border-[#00D02B]/35">
              <div class="flex-shrink-0 w-8 h-8 bg-[#00D02B] rounded flex items-center justify-center">
                <svg class="text-black w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h3 class="font-[Orbitron] text-sm font-bold text-white mb-1">{item.title}</h3>
                <p class="font-[Rajdhani] text-sm text-[#94A3B8] leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Team — White subtle section ── -->
    <section class="bg-[#F8FAFC] py-16 md:py-20 border-t border-[#E2E8F0]">
      <div class="max-w-4xl mx-auto px-4 sm:px-8 lg:px-12">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#00D02B]/[0.08] border border-[#00D02B]/25 rounded-sm mb-5">
          <span class="font-[Rajdhani] text-[10px] font-bold tracking-[3px] uppercase text-[#00D02B]">Team</span>
        </div>
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold text-[#050505] mb-8">
          Who's <span class="text-[#00D02B]">Behind This</span>
        </h2>
        <div class="flex flex-col md:flex-row items-center gap-8 bg-white border border-[#E2E8F0] rounded-xl p-6 md:p-8">
          <div class="flex-shrink-0">
            <img
              src={image.src}
              alt="Team"
              width="128"
              height="128"
              loading="lazy"
              class="w-24 h-24 md:w-32 md:h-32 rounded-full border-4 border-[#00D02B] object-cover"
            />
          </div>
          <div class="flex-1">
            <p class="font-[Rajdhani] text-base md:text-lg text-[#64748B] leading-relaxed">
              Our Xbox Gamertag Generator is designed to help gamers create unique, fun, and memorable Gamertags with ease. Whether you're looking for something cool, edgy, or completely random, our tool offers endless name ideas to suit every gaming style. We make it simple to find the perfect Gamertag so you can stand out and start playing faster.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA — Dark section with green top border ── -->
    <section class="bg-[#000000] border-t-[3px] border-t-[#00D02B] py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-8 lg:px-12 text-center">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold text-white mb-4">
          Ready to find your <span class="text-[#00D02B]">perfect tag?</span>
        </h2>
        <p class="font-[Rajdhani] text-base text-[#94A3B8] mb-8">
          Jump in and generate your ideal gamertag in seconds.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a
            href="/"
            class="inline-flex items-center justify-center px-8 py-3 bg-[#00D02B] hover:bg-[#00e830] text-black font-[Rajdhani] font-bold text-sm uppercase tracking-widest rounded transition-colors duration-200 w-full sm:w-auto"
          >
            Try the Generator
          </a>
          <a
            href="/tools"
            class="inline-flex items-center justify-center px-8 py-3 bg-transparent border border-[#1F2937] hover:border-[#94A3B8] text-white font-[Rajdhani] font-bold text-sm uppercase tracking-widest rounded transition-colors duration-200 w-full sm:w-auto"
          >
            Explore All Tools
          </a>
        </div>
      </div>
    </section>

  </div>
</MainLayout>