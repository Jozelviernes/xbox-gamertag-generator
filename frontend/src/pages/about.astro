---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import image from "../assets/image.png";

const pageUrl = "https://xboxgamertaggenerator.com/about";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Xbox Gamertag Generator",
    "url": pageUrl,
    "description": "Learn about Xbox Gamertag Generator, our mission, tools, and how we help gamers create better Xbox names.",
    "inLanguage": "en-US",
    "isPartOf": {
      "@type": "WebSite",
      "name": "Xbox Gamertag Generator",
      "url": "https://xboxgamertaggenerator.com"
    },
    "about": {
      "@type": "Organization",
      "name": "Xbox Gamertag Generator",
      "url": "https://xboxgamertaggenerator.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://xboxgamertaggenerator.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "About",
        "item": pageUrl
      }
    ]
  }
];

const features = [
  {
    title: "Xbox Gamertag Tools",
    desc: "Free tools to generate, check, and improve Xbox gamertags.",
  },
  {
    title: "Naming Guides and Tips",
    desc: "Helpful articles and practical advice for choosing better Xbox names.",
  },
  {
    title: "Profile and Lookup Tools",
    desc: "Resources for checking gamer profiles, availability, and related details.",
  },
  {
    title: "Gaming Identity Resources",
    desc: "Content and tools to help gamers build a stronger online identity.",
  },
];
---

<MainLayout
  title="About Xbox Gamertag Generator – Our Mission, Tools & Guides"
  description="Learn about Xbox Gamertag Generator, our mission, and the free tools, guides, and resources we build to help gamers create better Xbox names."
  canonical={pageUrl}
  ogImage={image.src}
  {schema}
>
  <Header />

  <div class="min-h-screen bg-[#F3F4F6] text-[#111827] font-ui">
    <!-- Hero -->
    <section class="bg-[#F3F4F6] py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-8 sm:px-12 lg:px-16 text-center md:text-left">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold mb-6 text-[#111827] leading-tight">
            About <span class="text-brand">Xbox GamerTag Generator</span>
          </h1>

          <h2 class="text-2xl md:text-3xl text-[#6B7280] mb-8 font-medium leading-snug">
            Helping gamers find their perfect name.
          </h2>

          <p class="text-lg md:text-xl text-[#374151] leading-relaxed max-w-3xl">
            We&apos;re dedicated to making naming effortless, creative, and fun—so you can focus on gaming.
          </p>
          
        </div>
      </div>
    </section>

    <!-- Brand Story + Mission -->
    <section class="py-16 md:py-20 bg-[#E5E7EB]">
      <div class="max-w-5xl mx-auto px-8 sm:px-12 lg:px-16">
        <div class="max-w-4xl mx-auto">
          <div class="mb-12">
            <h2 class="text-4xl md:text-5xl font-extrabold mb-8 text-center md:text-left text-[#111827]">
              Our <span class="text-brand">Story</span>
            </h2>

            <div class="border-l-4 border-brand pl-6 mb-8">
              <p class="text-base md:text-lg text-[#374151] leading-relaxed">
                Born from frustration with taken or cringe Xbox names, XboxGamerTagGenerator.com exists to help gamers create identities they&apos;re proud of. We know that your gamertag is your online persona, your first impression, and part of your gamer legacy.
              </p>
            </div>
          </div>

          <div>
            <h2 class="text-4xl md:text-5xl font-extrabold mb-8 text-center md:text-left text-[#111827]">
              Our <span class="text-brand">Mission</span>
            </h2>

            <div class="border-l-4 border-brand pl-6">
              <p class="text-base md:text-lg text-[#374151] leading-relaxed">
                Our mission is to simplify the naming process, offer creative inspiration, and make sure every gamer has a name worth shouting across the lobby.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What We Offer -->
    <section class="py-16 md:py-20 bg-[#F3F4F6]">
      <div class="max-w-5xl mx-auto px-8 sm:px-12 lg:px-16">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl md:text-5xl font-extrabold mb-10 text-center md:text-left text-[#111827]">
            What You&apos;ll Find <span class="text-brand">Here</span>
          </h2>

          <div class="space-y-6">
            {features.map((item) => (
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-8 h-8 bg-brand rounded-full flex items-center justify-center mt-0.5">
                  <svg class="text-white h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>

                <div>
                  <h3 class="text-xl md:text-2xl font-semibold mb-2 text-[#111827]">
                    {item.title}
                  </h3>
                  <p class="text-base md:text-lg text-[#4B5563] leading-relaxed">
                    {item.desc}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

  <!-- Team -->
<section class="py-16 md:py-20 bg-[#E5E7EB]">
  <div class="max-w-5xl mx-auto px-8 sm:px-12 lg:px-16">
    <div class="max-w-4xl mx-auto text-center md:text-left">
      <h2 class="text-4xl md:text-5xl font-extrabold mb-8 text-[#111827]">
        Who&apos;s <span class="text-brand">Behind This</span>
      </h2>

      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex-shrink-0 text-center">
          <img
            src={image.src}
            alt="Jonathan Caldwell"
            width="128"
            height="128"
            loading="lazy"
            class="w-32 h-32 rounded-full border-4 border-brand object-cover mx-auto"
          />

          <h3 class="mt-4 text-2xl font-bold text-[#111827]">
            Jonathan Caldwell
          </h3>
          <p class="text-brand font-semibold mt-1">
            Founder &amp; Gaming Expert
          </p>
        </div>

        <div class="flex-1">
          <p class="text-base md:text-lg text-[#374151] leading-relaxed">
            Jonathan is a gaming enthusiast and Xbox community expert who created this tool after experiencing the frustration of finding the perfect gamertag. With years of experience in the gaming community, he understands what makes a great gamertag and how to help gamers find their perfect online identity.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>



    <!-- CTA -->
    <section class="py-16 md:py-20 bg-[#F3F4F6]">
      <div class="max-w-5xl mx-auto px-8 sm:px-12 lg:px-16 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-4xl md:text-5xl font-extrabold mb-8 text-[#111827] leading-tight">
            Ready to find your <span class="text-brand">perfect tag?</span>
          </h2>

          <p class="text-base md:text-lg text-[#4B5563] mb-8">
            Jump in and generate your ideal gamertag in seconds.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a
              href="/"
              class="bg-brand hover:bg-brand-light text-white font-semibold px-8 py-4 rounded-lg transition-all duration-200 w-full sm:w-auto min-h-[48px] inline-flex items-center justify-center"
            >
              Try the Generator
            </a>

            <a
              href="/tools"
              class="text-brand hover:text-brand-light font-medium underline decoration-2 underline-offset-4 min-h-[48px] flex items-center"
            >
              Explore All Tools
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</MainLayout>