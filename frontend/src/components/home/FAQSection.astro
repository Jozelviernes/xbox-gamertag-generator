<!-- Full-width light grey section — matches ReactJS bg-light-grey-subtle -->
<section
  class="py-7 md:py-20"
  style="background-color: hsl(220 14% 96%); width: 100vw; position: relative; left: 50%; right: 50%; margin-left: -50vw; margin-right: -50vw;"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="text-center mb-10 sm:mb-12">

      <!-- FAQ badge -->
      <div class="inline-flex items-center mb-4"
           style="background: hsl(107 76% 26% / 0.08); border: 1px solid hsl(107 76% 26% / 0.25); border-radius: 3px; padding: 3px 12px;">
        <span style="font-family:'Inter',sans-serif; font-size:10px; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color: hsl(107 76% 26%);">
          FAQ
        </span>
      </div>

      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-3"
          style="font-family:'Inter',sans-serif; color: hsl(218 30% 9%); letter-spacing: -0.02em;">
        FAQ: Your New Gamertag — What You Need to Know
      </h2>

      <p class="text-sm max-w-xl mx-auto"
         style="font-family:'Inter',sans-serif; color: hsl(215 16% 47%); line-height: 1.6;">
        Everything you need to know about creating the perfect Xbox gamertag.
      </p>
    </div>

    <!-- Accordion list -->
    <div class="flex flex-col gap-3" id="faq-list">

      {faqItems.map((item) => (
        <div
          class="faq-item w-full overflow-hidden rounded-lg"
          data-faq-id={item.id}
          style="background: #ffffff; border: 1px solid hsl(220 13% 91%); box-shadow: 0 2px 8px hsl(218 30% 9% / 0.06); transition: border-color 0.2s ease, box-shadow 0.2s ease;"
        >
          <!-- Toggle button -->
          <button
            class="faq-toggle w-full flex items-center justify-between gap-4 text-left px-5 py-4 sm:px-6 sm:py-5"
            type="button"
            aria-expanded="false"
            data-id={item.id}
            style="background: transparent; border: none; cursor: pointer; outline: none; touch-action: manipulation;"
          >
            <span
              class="faq-question text-sm sm:text-base font-semibold flex-1"
              style="font-family:'Inter',sans-serif; color: hsl(218 20% 16%); line-height: 1.4; transition: color 0.2s ease;"
            >
              {item.question}
            </span>

            <!-- Chevron icon — rotates 180deg when open -->
            <svg
              class="faq-chevron flex-shrink-0"
              width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="currentColor"
              stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
              style="color: hsl(107 76% 26%); transition: transform 0.25s cubic-bezier(0.4,0,0.2,1); flex-shrink: 0;"
            >
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>

          <!-- Collapsible content — hidden by default via max-height: 0 -->
          <div
            class="faq-content"
            aria-hidden="true"
            style="max-height: 0; overflow: hidden; transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1);"
          >
            <!-- Divider -->
            <div class="mx-5 sm:mx-6" style="height:1px; background: hsl(220 13% 91%);"></div>

            <div class="px-5 sm:px-6 py-4 sm:py-5 flex flex-col gap-4">

              {item.answer.split('[AD_BANNER]').map((part, index, arr) => (
                <>
                  {part.trim() && (
                    <p
                      class="text-sm leading-relaxed whitespace-pre-line"
                      style="font-family:'Inter',sans-serif; color: hsl(215 16% 47%); line-height: 1.75;"
                    >
                      {part.trim()}
                    </p>
                  )}

                  {index < arr.length - 1 && (
                    <div
                      class="rounded-lg text-center"
                      style="padding: 12px 14px; background: linear-gradient(to right, hsl(107 76% 26% / 0.08), hsl(107 76% 26% / 0.04)); border: 1px solid hsl(107 76% 26% / 0.2);"
                    >
                      <p style="font-family:'Inter',sans-serif; font-size:10px; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color: hsl(107 76% 26%); margin-bottom: 8px;">
                        Advertisement
                      </p>
                      <div
                        class="rounded bg-white/50"
                        style="border: 2px dashed hsl(107 76% 26% / 0.3); padding: 1.5rem 1rem;"
                      >
                        <p style="font-family:'Inter',sans-serif; font-size:12px; color: hsl(215 16% 60%);">
                          Ad Banner Space
                        </p>
                      </div>
                    </div>
                  )}
                </>
              ))}

            </div>
          </div>

        </div>
      ))}

    </div>
  </div>
</section>

<style>
  /* Card hover — white stays white, green border tint */
  .faq-item:hover {
    background: #ffffff !important;
    border-color: hsl(107 76% 26% / 0.3) !important;
    box-shadow: 0 4px 16px hsl(218 30% 9% / 0.1) !important;
  }

  /* Open state — white card, green border */
  .faq-item.is-open {
    background: #ffffff !important;
    border-color: hsl(107 76% 26% / 0.4) !important;
    box-shadow: 0 4px 20px hsl(218 30% 9% / 0.1) !important;
  }
  .faq-item.is-open .faq-question {
    color: hsl(107 76% 26%) !important;
  }
  .faq-item.is-open .faq-chevron {
    transform: rotate(180deg) !important;
  }

  /* Toggle hover — very light grey, matches ReactJS hover:bg-gray-50 */
  .faq-toggle:hover {
    background-color: hsl(220 13% 97%) !important;
  }

  /* Answer text stays dark-on-light always */
  .faq-answer-text,
  .faq-content p {
    color: hsl(215 16% 47%) !important;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .faq-content { transition: none !important; }
    .faq-chevron { transition: none !important; }
  }
</style>

<script is:inline>
  function initFaq() {
    document.querySelectorAll('.faq-toggle').forEach(function(btn) {
      if (btn.dataset.bound === 'true') return;
      btn.dataset.bound = 'true';

      btn.addEventListener('click', function() {
        var item    = btn.closest('.faq-item');
        var content = item ? item.querySelector('.faq-content') : null;
        if (!item || !content) return;

        var isOpen = item.classList.contains('is-open');

        /* Close ALL items first */
        document.querySelectorAll('.faq-item').forEach(function(el) {
          el.classList.remove('is-open');
          var c = el.querySelector('.faq-content');
          if (c) c.style.maxHeight = '0';
          var t = el.querySelector('.faq-toggle');
          if (t) t.setAttribute('aria-expanded', 'false');
        });

        /* If it was closed, open it */
        if (!isOpen) {
          item.classList.add('is-open');
          content.style.maxHeight = content.scrollHeight + 'px';
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  initFaq();
  document.addEventListener('astro:page-load', initFaq);
</script>