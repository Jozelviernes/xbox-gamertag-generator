---
import Search from "@lucide/astro/icons/search";
import BarChart3 from "@lucide/astro/icons/chart-column";
import Download from "@lucide/astro/icons/download";
import DollarSign from "@lucide/astro/icons/dollar-sign";
import UserCheck from "@lucide/astro/icons/user-check";
import Gift from "@lucide/astro/icons/gift";

type Tool = {
  id: string;
  title: string;
  description: string;
  icon: typeof Search;
  slug: string;
  comingSoon?: boolean;
};

const tools: Tool[] = [
  
     {
    id: "1",
    title: "Xbox Gamertag Generator",
    description: "Instantly create unique, funny, and cool gamertags with AI-powered suggestions.",
    slug: "/",
    icon: UserCheck,
  },
   {
    id: "2",
    title: "Xbox Gamercard Generator",
    description: "Create a custom Xbox gamercard badge showing your gamertag, gamerscore, and avatar.",
    icon: Gift,
    slug: "gamercard-generator",
  },
  {
    id: "3",
    title: "Xbox Gamertag Price Checker",
    description: "Estimate the potential market value of any gamertag based on length, rarity, and demand.",
    icon: DollarSign,
    slug: "price-checker",
  },
 
  {
    id: "4",
    title: "Xbox Gamer Profile & Stats Checker",
    description: "View public stats, gamerscore, recent games, and achievement progress tied to any gamertag.",
    icon: BarChart3,
    slug: "profile-stats-checker",
      comingSoon: true,
  },
  {
  
    id: "5",
    title: "Xbox Gamertag Availability Checker",
    description: "Instantly see if your desired tag is still up for grabs before someone else snags it.",
    icon: Search,
    slug: "availability-checker",
      comingSoon: true,
  }
];

const getToolLink = (slug: string): string => {
  // if homepage
  if (slug === "/") return "/";

  const map: Record<string, string> = {
    "gamercard-generator": "/gamercard-generator",
    "price-checker": "/gamertag-price-checker",
    "profile-stats-checker": "/gamer-profile-checker",
    "availability-checker": "/gamertag-availability-checker",
    "account-value-checker": "/account-value-checker",
    "clips-downloader": "/clips-downloader",
  };

  return map[slug] ?? `/${slug}`;
};

---

<section class="section-white-subtle py-16 md:py-20 border-t border-[#E5E7EB]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 md:px-8">

    <!-- Section Header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10 md:mb-12">
      <div>
        <span class="inline-block mb-3 px-3 py-1 rounded-full text-[11px] md:text-xs font-bold tracking-[0.18em] uppercase text-[#00B324] bg-[#00D02B]/10 border border-[#00D02B]/20">
          Free Tools
        </span>
        <h2 class="font-ui text-3xl md:text-4xl font-extrabold tracking-tight text-[#111827] leading-tight">
          Explore More <span class="text-[#00B324]">Tools</span>
        </h2>
      </div>

      <a
        href="/tools"
        class="inline-flex items-center gap-2 text-base md:text-lg font-semibold text-[#00B324] hover:text-[#00961e] transition-colors"
      >
        View All Tools
        <svg
          class="w-4 h-4 transition-transform hover:translate-x-0.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6 mb-8">
  {tools.map((tool) => {
    const Icon = tool.icon;
    return tool.comingSoon ? (

      <!-- COMING SOON (ICON TOP + BADGE RIGHT) -->
      <div class="bg-white border border-[#E5E7EB] rounded-2xl p-5 md:p-6 shadow-[0_8px_24px_rgba(15,23,42,0.04)] flex flex-col h-full opacity-80">

        <!-- ICON + BADGE -->
        <div class="flex items-center justify-between mb-4">
          <div class="w-11 h-11 md:w-12 md:h-12 rounded-xl flex items-center justify-center bg-[#F3F4F6] border border-[#E5E7EB]">
            <Icon class="h-5 w-5 md:h-6 md:w-6 text-[#94A3B8]" />
          </div>

          <span class="px-2 py-1 rounded-full text-[9px] md:text-[10px] font-bold uppercase tracking-[0.12em] text-[#6B7280] bg-[#F3F4F6] border border-[#E5E7EB] whitespace-nowrap">
            Coming Soon
          </span>
        </div>

        <!-- TITLE -->
        <h3 class="font-ui text-base md:text-lg font-extrabold text-[#374151] leading-snug mb-2">
          {tool.title}
        </h3>

        <!-- DESCRIPTION -->
        <p class="font-ui text-sm md:text-[15px] leading-7 text-[#6B7280] mb-4">
          {tool.description}
        </p>

        <!-- BUTTON -->
        <div class="mt-auto">
          <button
            disabled
            class="w-full bg-[#E5E7EB] text-[#9CA3AF] text-sm md:text-[15px] font-semibold px-4 py-2.5 rounded-lg cursor-not-allowed"
          >
            Coming Soon
          </button>
        </div>

      </div>

    ) : (

      <!-- AVAILABLE TOOL -->
      <div class="group bg-white border border-[#E5E7EB] rounded-2xl p-5 md:p-6 shadow-[0_8px_24px_rgba(15,23,42,0.04)] hover:shadow-[0_14px_32px_rgba(15,23,42,0.08)] hover:-translate-y-0.5 transition-all duration-200 flex flex-col h-full">

        <!-- ICON -->
        <div class="w-11 h-11 md:w-12 md:h-12 rounded-xl flex items-center justify-center bg-[#00D02B]/10 border border-[#00D02B]/20 mb-4">
          <Icon class="h-5 w-5 md:h-6 md:w-6 text-[#00B324]" />
        </div>

        <!-- TITLE -->
        <h3 class="font-ui text-base md:text-lg font-extrabold text-[#111827] leading-snug mb-2 group-hover:text-[#00B324] transition-colors">
          {tool.title}
        </h3>

        <!-- DESCRIPTION -->
        <p class="font-ui text-sm md:text-[15px] leading-7 text-[#4B5563] mb-4">
          {tool.description}
        </p>

        <!-- BUTTON -->
        <div class="mt-auto">
          <a
            href={getToolLink(tool.slug)}
            class="block w-full text-center bg-[#00B324] hover:bg-[#00961e] text-white text-sm md:text-[15px] font-semibold px-4 py-2.5 rounded-lg transition-colors"
          >
            Go to Tool
          </a>
        </div>

      </div>

    );
  })}
</div>



    <!-- Ad Banner -->
    <div class="bg-[#F3F4F6] rounded-xl px-4 md:px-6 py-6 text-center border-2 border-dashed border-[#D1D5DB] mt-8">
      <p class="font-ui text-sm md:text-base text-[#6B7280] mb-2">Advertisement</p>
      <div class="h-20 md:h-32 lg:h-40 bg-[#E5E7EB] rounded-lg"></div>
    </div>

  </div>
</section>