---
import { blogPosts } from "../../data/blogPosts";

const featuredPosts = blogPosts.slice(0, 6);
---

<section class="pt-8 pb-16 bg-light-grey">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bebas text-xbox-green text-center mb-12">
      Featured Gaming Guides
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredPosts.map((post) => (
        <article class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-shadow group">
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-800 mb-3 group-hover:text-xbox-green transition-colors">
              {post.title}
            </h3>

            <p class="text-gray-600 mb-4 line-clamp-3">
              {post.excerpt}
            </p>

            <div class="flex items-center justify-between gap-4">
              <div class="flex items-center text-sm text-gray-500">
                <span class="mr-1">🕒</span>
                {post.readTime}
              </div>

              
                <a href={`/blog/${post.slug}`}
                class="text-xbox-green hover:text-xbox-green-light font-medium inline-flex items-center group-hover:translate-x-1 transition-transform"
              >
                Read More <span class="ml-1">→</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-12">
      
        href="/blog"
        class="inline-flex items-center px-6 py-3 bg-xbox-green hover:bg-xbox-green-light text-white font-semibold rounded-lg transition-colors shadow-xbox"
      >
        View All Posts <span class="ml-2">→</span>
      </a>
    </div>

    <div class="bg-gray-100 rounded-lg px-4 md:px-6 py-6 text-center border-2 border-dashed border-gray-300 mt-8">
      <p class="text-xs md:text-sm text-gray-500 mb-2">Advertisement</p>
      <div class="h-20 md:h-32 lg:h-40 bg-gray-200 rounded"></div>
    </div>
  </div>
</section>