---
import Menu from "@lucide/astro/icons/menu";

const currentPath = Astro.url.pathname;

const navigation = [
  { name: "Home", path: "/" },
  { name: "Blog", path: "/blog" },
  { name: "Tools", path: "/tools" },
  { name: "Glossary", path: "/glossary" },
  { name: "About", path: "/about" },
  { name: "Contact", path: "/contact" },
];

const normalizePath = (path: string) =>
  path !== "/" && path.endsWith("/") ? path.slice(0, -1) : path;

const isActive = (path: string) =>
  normalizePath(currentPath) === normalizePath(path);
---

<header class="navbar border-default">
  <nav class="container-responsive flex h-16 items-center justify-between gap-4 md:h-[72px]">
    <a
      href="/"
      aria-label="Xbox Gamertag Generator home"
      class="flex min-w-0 items-center gap-3"
    >
  <img
  src="/logo.webp"
  alt="Xbox Gamertag Generator logo"
  width="40"
  height="40"
  loading="eager"
  decoding="async"
  fetchpriority="high"
  class="h-10 w-10 shrink-0 object-contain"
/>git 
      <div class="min-w-0 leading-none">
        <span class="font-site-title block truncate text-sm font-black uppercase tracking-[0.18em] text-foreground md:text-base">
          Xbox
        </span>
        <span class="block truncate font-ui text-[0.62rem] font-bold uppercase tracking-[0.22em] text-brand md:text-[0.7rem]">
          Gamertag Generator
        </span>
      </div>
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-6 md:flex">
      {navigation.map((item) => (
        <a
          href={item.path}
          aria-current={isActive(item.path) ? "page" : undefined}
          class:list={[
            "relative inline-flex h-10 items-center font-ui text-[12px] font-bold uppercase tracking-[0.12em] transition-colors duration-200",
            "text-foreground-muted hover:text-foreground",
            "after:absolute after:left-0 after:right-0 after:bottom-1 after:h-[2px] after:origin-center after:rounded-full after:bg-brand after:transition-transform after:duration-300",
            isActive(item.path) ? "text-foreground after:scale-x-100" : "after:scale-x-0 hover:after:scale-x-100"
          ]}
        >
          {item.name}
        </a>
      ))}
    </div>

   <!-- Mobile nav -->
<details class="md:hidden">
  <summary class="flex h-11 w-11 cursor-pointer items-center justify-center rounded-[var(--radius)] border border-default bg-[hsl(218_30%_14%)] text-foreground transition-colors duration-200 hover:border-[hsl(107_76%_26%_/_0.35)] hover:bg-[hsl(107_76%_26%_/_0.08)] hover:text-brand">
    <span class="sr-only">Toggle navigation menu</span>
    <Menu class="h-5 w-5" />
  </summary>

  <div class="absolute left-0 right-0 top-full -mt-px z-50 border-y border-default bg-background-alt px-4 py-4 shadow-card">
    <div class="flex flex-col">
      {navigation.map((item) => (
        <a
          href={item.path}
          aria-current={isActive(item.path) ? "page" : undefined}
          class:list={[
            "flex items-center justify-center text-center border-b border-[hsl(218_30%_18%)] py-3 font-ui text-[13px] font-bold uppercase tracking-[0.12em] transition-colors duration-200 last:border-b-0",
            isActive(item.path) ? "text-brand" : "text-foreground hover:text-brand"
          ]}
        >
          {item.name}
        </a>
      ))}
    </div>
  </div>
</details>
    
  </nav>
</header>