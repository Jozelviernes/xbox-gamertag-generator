---
---

<footer class="bg-[#050505] border-t border-[#1F2937]">

  <!-- Top divider with green center glow -->
  <div class="h-px w-full" style="background: linear-gradient(90deg, transparent, #1F2937 20%, #00D02B 50%, #1F2937 80%, transparent);"></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 md:py-12">

    <!-- Logo + tagline -->
    <div class="flex flex-col items-center text-center mb-8">
      <div class="flex items-center gap-2 mb-2">
        <div class="w-6 h-6 border-2 border-[#00D02B] rounded flex items-center justify-center">
          <div class="w-2.5 h-2.5 bg-[#00D02B] rounded-sm"></div>
        </div>
        <span class="font-[Orbitron] text-sm font-bold text-white tracking-widest uppercase">
          Xbox Gamertag Generator
        </span>
      </div>
      <p class="font-[Rajdhani] text-xs text-[#4B5563] tracking-wider uppercase">
        Forge Your Identity. Own the Game.
      </p>
    </div>

    <!-- Nav links -->
    <div class="flex items-center justify-center flex-wrap gap-x-6 gap-y-3 mb-8">
      <a href="/" class="font-[Rajdhani] text-sm font-600 text-[#94A3B8] uppercase tracking-wide hover:text-[#00D02B] transition-colors duration-150">
        Gamertag Generator
      </a>
      <span class="text-[#1F2937] hidden sm:inline">|</span>
      <a href="/tools" class="font-[Rajdhani] text-sm font-600 text-[#94A3B8] uppercase tracking-wide hover:text-[#00D02B] transition-colors duration-150">
        Gaming Tools
      </a>
      <span class="text-[#1F2937] hidden sm:inline">|</span>
      <a href="/blog" class="font-[Rajdhani] text-sm font-600 text-[#94A3B8] uppercase tracking-wide hover:text-[#00D02B] transition-colors duration-150">
        Gaming Guides
      </a>
      <span class="text-[#1F2937] hidden sm:inline">|</span>
      <a href="/about" class="font-[Rajdhani] text-sm font-600 text-[#94A3B8] uppercase tracking-wide hover:text-[#00D02B] transition-colors duration-150">
        About Us
      </a>
      <span class="text-[#1F2937] hidden sm:inline">|</span>
      <a href="/contact" class="font-[Rajdhani] text-sm font-600 text-[#94A3B8] uppercase tracking-wide hover:text-[#00D02B] transition-colors duration-150">
        Contact
      </a>
    </div>

    <!-- Divider -->
    <div class="border-t border-[#1F2937] mb-8"></div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-5">

      <!-- Copyright -->
      <p class="font-[Rajdhani] text-xs text-[#4B5563] tracking-wide text-center sm:text-left">
        © 2025 Xbox Gamertag Generator. All rights reserved.
      </p>

      <!-- Legal links -->
      <div class="flex items-center gap-5">
        <a href="/terms-and-conditions" class="font-[Rajdhani] text-xs text-[#4B5563] uppercase tracking-wider hover:text-[#00D02B] transition-colors duration-150">
          Terms &amp; Conditions
        </a>
        <span class="text-[#1F2937]">|</span>
        <a href="/privacy-policy" class="font-[Rajdhani] text-xs text-[#4B5563] uppercase tracking-wider hover:text-[#00D02B] transition-colors duration-150">
          Privacy Policy
        </a>
      </div>

      <!-- Social icons -->
      <div class="flex items-center gap-4">
        <a
          href="https://x.com/xbox_tag_gen"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Twitter / X"
          class="w-8 h-8 flex items-center justify-center border border-[#1F2937] rounded text-[#4B5563] hover:border-[#00D02B]/40 hover:text-[#00D02B] transition-all duration-150"
        >
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.9 2H22l-6.77 7.74L23.2 22h-6.25l-4.9-6.44L6.42 22H3.3l7.24-8.27L.8 2h6.4l4.43 5.85L18.9 2Zm-1.1 18h1.73L6.26 3.9H4.4L17.8 20Z"/>
          </svg>
        </a>

        <a
          href="https://www.facebook.com/xboxgamertaggenerator/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="w-8 h-8 flex items-center justify-center border border-[#1F2937] rounded text-[#4B5563] hover:border-[#00D02B]/40 hover:text-[#00D02B] transition-all duration-150"
        >
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
            <path d="M22 12.07C22 6.5 17.52 2 12 2S2 6.5 2 12.07C2 17.1 5.66 21.27 10.44 22v-7.03H7.9v-2.9h2.54V9.84c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.25.2 2.25.2v2.48H15.2c-1.25 0-1.64.78-1.64 1.58v1.88h2.8l-.45 2.9h-2.35V22C18.34 21.27 22 17.1 22 12.07Z"/>
          </svg>
        </a>
      </div>

    </div>
  </div>
</footer>