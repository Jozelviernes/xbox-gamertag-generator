  </div>
</footer>

<style>
  .footer-link {
    font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
    color: hsl(215 20% 55%);
    text-decoration: none;
    transition: color 0.15s ease;
    touch-action: manipulation;
  }
  .footer-link:hover {
    color: hsl(107 76% 42%);
  }

  .footer-social {
    color: hsl(215 20% 55%);
    transition: color 0.15s ease;
    touch-action: manipulation;
  }
  .footer-social:hover {
    color: hsl(107 76% 42%);
  }
</style>