<footer class="border-t py-8" style="background-color: hsl(218 30% 9%); border-color: hsl(218 30% 18%);">
  <div class="max-w-5xl mx-auto px-6">

    <!-- ═══ DESKTOP (md+) — matches ReactJS hidden md:block ═══ -->
    <div class="hidden md:flex flex-col items-center text-center gap-6">

      <!-- Nav links -->
      <div class="flex items-center justify-center flex-wrap gap-6 text-sm">
        <a href="/" class="footer-link">Gamertag Generator</a>
        <a href="/tools" class="footer-link">Gaming Tools</a>
        <a href="/blog" class="footer-link">Gaming Guides</a>
        <a href="/about" class="footer-link">About Us</a>
        <a href="/contact" class="footer-link">Contact</a>
      </div>

      <!-- Legal links -->
      <div class="flex items-center gap-8 text-sm">
        <a href="/terms-and-conditions" class="footer-link">Terms &amp; Conditions</a>
        <a href="/privacy-policy" class="footer-link">Privacy Policy</a>
      </div>

      <!-- Copyright -->
      <div class="text-sm" style="color: hsl(215 20% 55%); font-family: 'Inter', sans-serif;">
        <p>© 2025 Xbox Gamertag Generator.</p>
        <p>All rights reserved.</p>
      </div>

      <!-- Social icons -->
      <div class="flex items-center gap-6">
        <!-- Twitter / X -->
        <a href="https://x.com/xbox_tag_gen" target="_blank" rel="noopener noreferrer"
           aria-label="Twitter / X" class="footer-social">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M18.9 2H22l-6.77 7.74L23.2 22h-6.25l-4.9-6.44L6.42 22H3.3l7.24-8.27L.8 2h6.4l4.43 5.85L18.9 2Zm-1.1 18h1.73L6.26 3.9H4.4L17.8 20Z"/>
          </svg>
        </a>
        <!-- Facebook -->
        <a href="https://www.facebook.com/xboxgamertaggenerator/" target="_blank" rel="noopener noreferrer"
           aria-label="Facebook" class="footer-social">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M22 12.07C22 6.5 17.52 2 12 2S2 6.5 2 12.07C2 17.1 5.66 21.27 10.44 22v-7.03H7.9v-2.9h2.54V9.84c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.25.2 2.25.2v2.48H15.2c-1.25 0-1.64.78-1.64 1.58v1.88h2.8l-.45 2.9h-2.35V22C18.34 21.27 22 17.1 22 12.07Z"/>
          </svg>
        </a>
      </div>

    </div>

    <!-- ═══ MOBILE (below md) — matches ReactJS md:hidden ═══ -->
    <div class="md:hidden text-center flex flex-col gap-6">

      <!-- Legal links -->
      <div class="flex flex-col gap-4">
        <a href="/terms-and-conditions" class="footer-link">Terms &amp; Conditions</a>
        <a href="/privacy-policy" class="footer-link">Privacy Policy</a>
      </div>

      <!-- Copyright -->
      <div class="text-sm" style="color: hsl(215 20% 55%); font-family: 'Inter', sans-serif;">
        <p>© 2025 Xbox Gamertag Generator.</p>
        <p>All rights reserved.</p>
      </div>

      <!-- Social icons -->
      <div class="flex justify-center gap-6">
        <a href="https://x.com/xbox_tag_gen" target="_blank" rel="noopener noreferrer"
           aria-label="Twitter / X" class="footer-social">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M18.9 2H22l-6.77 7.74L23.2 22h-6.25l-4.9-6.44L6.42 22H3.3l7.24-8.27L.8 2h6.4l4.43 5.85L18.9 2Zm-1.1 18h1.73L6.26 3.9H4.4L17.8 20Z"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/xboxgamertaggenerator/" target="_blank" rel="noopener noreferrer"
           aria-label="Facebook" class="footer-social">
